                                <label class="muted">
                                    <%= t("report_target") %>
                                </label><br />
                            </label><br />
                            <select id="vcReportCh" style="width:100%; margin-top:5px;"></select>
                        </div>
                        <div>
                            <label class="muted">
                                <label class="muted">
                                    <%= t("send_interval") %>
                                </label><br />
                            </label><br />
                            <select id="vcReportInterval" style="width:100%; margin-top:5px;">
                                <option value="daily">
                                    <%= t("interval_daily") %>
                                </option>
                                <option value="weekly" selected>
                                    <%= t("interval_weekly") %>
                                </option>
                                <option value="monthly">
                                    <%= t("interval_monthly") %>
                                </option>
                            </select>
                        </div>
                    </div>
                </div>

                <!-- Dynamic VC (Auto-VC) -->
                <div style="border-top:1px solid var(--border-color); padding-top:20px; margin-top:20px;">
                    <label class="muted" style="font-size:12px;">
                        <%= t("auto_vc_cat_label") %><span class="help-tip" data-tip="<%= t(" help_auto_vc")
                                %>">?</span>
                    </label><br />
                    <select id="autoVcCategory" style="width:100%; max-width:400px; margin-top:5px;"></select>
                    <p class="muted" style="font-size:11px; margin-top:5px;">
                        <%= t("auto_vc_help") %>
                    </p>
                </div>
            </div>
        </div>


        <!-- 7. Button Roles (v2.8.0) -->
        <div class="accordion-item" id="sec-br">
            <div class="accordion-header" onclick="toggleAccordion('sec-br')">
                <span>
                    🔘 <%= t("br_mgmt_title") %><span class="help-tip" data-tip="<%= t('help_br_mgmt') %>">?</span>
                </span>
                <span>▼</span>
            </div>
            <div class="accordion-content">
                <p class="muted" style="font-size:12px; margin-bottom:15px;">
                    <%= t("br_mgmt_desc") %>
                </p>
                <!-- Creator Form -->
                <div
                    style="background: rgba(0,0,0,0.1); padding: 15px; border-radius: 8px; margin-bottom: 25px; border: 1px solid var(--border-color);">
                    <h5 style="margin:20px 0 10px 0; color:var(--text-primary); font-size:14px;">
                        <%= t("br_panel_edit_title") %>
                    </h5>
                    <input type="hidden" id="brId" value="">
                    <input type="hidden" id="brMessageId" value="">

                    <div style="display:grid; grid-template-columns: 1fr 1fr; gap:15px; margin-bottom:15px;">
                        <div>
                            <label class="muted">
                                <%= t("target_channel") %>
                            </label><br />
                            <select id="brChannel" style="width:100%; margin-top:5px;"></select>
                        </div>
                        <div>
                            <label class="muted">
                                <%= t("accent_color_label") %>
                            </label><br />
                            <div style="display:flex; gap:10px; align-items:center; margin-top:5px;">
                                <input type="color" id="brColor" value="#5865F2"
                                    style="width:40px; height:35px; border:none; padding:0; background:none; cursor:pointer;"
                                    oninput="document.getElementById('brColorHex').value = this.value.toUpperCase()">
                                <input type="text" id="brColorHex" value="#5865F2"
                                    style="flex:1; font-family:monospace; text-transform:uppercase;" maxlength="7"
                                    oninput="document.getElementById('brColor').value = this.value">
                            </div>
                        </div>
                    </div>

                    <div style="margin-bottom:15px;">
                        <label class="muted">
                            <%= t("embed_title_label") %>
                        </label><br />
                        <input id="brTitle" type="text" placeholder="<%= t(" br_default_title") %>" style="width:100%;
                        margin-top:5px;">
                    </div>

                    <div style="margin-bottom:15px;">
                        <label class="muted" style="font-size:12px;">
                            <%= t("message_body_label") %>
                        </label><br />
                        <textarea id="brContent" rows="2" placeholder="<%= t(" br_empty_content_desc")
                            %>" style="width:100%; margin-top:5px; background:var(--card-bg); color:var(--text-primary); border:1px solid var(--border-color); border-radius:6px; padding:8px; font-size:13px;"></textarea>
                    </div>

                    <div style="margin-bottom:15px;">
                        <label class="muted">
                            <%= t("btn_settings_label") %>
                        </label>
                        <div id="brButtonsList" style="display:flex; flex-direction:column; gap:8px; margin-top:8px;">
                            <!-- Button Rows loaded via JS -->
                        </div>
                        <button type="button" onclick="addBrButton()" class="btn"
                            style="font-size:12px; width:100%; margin-top:10px; background:rgba(255,255,255,0.05); border:1px dashed var(--border-color);">+
                            <%= t("add_btn_label") %>
                        </button>
                    </div>

                    <div style="display:flex; gap:10px; margin-top:20px;">
                        <button class="btn btn-primary" onclick="deployBrPanel()">
                            <%= t("send_to_discord_btn") %>
                        </button>
                        <button class="btn btn-secondary" onclick="resetBrForm()">
                            <%= t("reset_btn") %>
                        </button>
                    </div>
                </div>

                <h4 style="font-size:14px; margin-bottom:12px; display:flex; align-items:center; gap:8px;">
                    <span style="width:8px; height:8px; background:var(--accent-color); border-radius:50%;"></span>
                    <%= t("br_list_title") %>
                </h4>
                <div id="br-loading" class="muted" style="text-align:center; padding:15px; display:none;">
                    <%= t("loading_dots") %>
                </div>
                <div id="br-list" style="display:flex; flex-direction:column; gap:12px;">
                    <!-- Button Role List Items -->
                </div>
            </div>
        </div>

    </div>
</div>


<!-- ACCORDION END -->



<div style="margin-top:30px; display:flex; gap:15px;">
    <button id="save" class="btn btn-primary" style="flex:1; padding:12px; font-size:16px;">
        <%= t("save_settings") %>
    </button>
</div>