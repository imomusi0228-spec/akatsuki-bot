<div class="card" style="max-width: 1000px;">
    <h3>🎨 <%= t("embed_builder") || "Embed Builder" %>
    </h3>
    <p class="muted">お嬢様の意志を、Discord上で最も美しく表現するための「詔（みことのり）」作成エディタです。</p>

    <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 30px; margin-top:30px;">
        <!-- Editor -->
        <div class="editor-pane" style="display:flex; flex-direction:column; gap:20px;">
            <div class="setting-item">
                <label class="muted">送信先チャンネル</label>
                <select id="embedTargetCh" style="width:100%; margin-top:8px;"></select>
            </div>

            <div class="setting-item">
                <label class="muted">タイトル</label>
                <input id="embedTitle" type="text" placeholder="タイトルを入力..." style="width:100%; margin-top:8px;"
                    oninput="updatePreview()">
            </div>

            <div class="setting-item">
                <label class="muted">説明文 (Markdown可)</label>
                <textarea id="embedDesc" rows="6" placeholder="お嬢様のメッセージをここに..."
                    style="width:100%; margin-top:8px; resize:vertical;" oninput="updatePreview()"></textarea>
            </div>

            <div style="display:grid; grid-template-columns: 1fr 1fr; gap:15px;">
                <div class="setting-item">
                    <label class="muted">アクセントカラー</label>
                    <input id="embedColor" type="color" value="#5865F2"
                        style="width:100%; height:40px; margin-top:8px; padding:0; border:none; background:none; cursor:pointer;"
                        oninput="updatePreview()">
                </div>
                <div class="setting-item">
                    <label class="muted">フッターテキスト</label>
                    <input id="embedFooter" type="text" placeholder="Footer text..." style="width:100%; margin-top:8px;"
                        oninput="updatePreview()">
                </div>
            </div>

            <div class="setting-item">
                <label class="muted">画像 URL</label>
                <input id="embedImage" type="text" placeholder="https://..." style="width:100%; margin-top:8px;"
                    oninput="updatePreview()">
            </div>

            <button id="sendEmbed" class="btn btn-primary" style="margin-top:10px; padding:12px; font-weight:bold;">
                📢 この内容で布告する
            </button>
        </div>

        <!-- Preview -->
        <div class="preview-pane">
            <label class="muted" style="display:block; margin-bottom:10px;">プレビュー (Real-time)</label>
            <div
                style="background: #313338; border-radius: 8px; padding: 20px; font-family: 'Helvetica Neue', Helvetica, Arial, sans-serif;">
                <div id="previewCard"
                    style="border-left: 4px solid #5865F2; background: #2b2d31; padding: 12px 16px; border-radius: 4px;">
                    <div id="pvTitle" style="color: #ffffff; font-weight: 700; font-size: 16px; margin-bottom: 8px;">
                        Embed Title</div>
                    <div id="pvDesc"
                        style="color: #dbdee1; font-size: 14px; white-space: pre-wrap; line-height: 1.375;">Your
                        description will appear here...</div>
                    <img id="pvImage" src=""
                        style="max-width: 100%; border-radius: 4px; margin-top: 12px; display: none;">
                    <div id="pvFooter" style="color: #949ba4; font-size: 12px; margin-top: 8px;">Footer Text</div>
                </div>
            </div>

            <p class="muted" style="font-size:12px; margin-top:20px; line-height:1.5;">
                ※ Markdown記法（ **太字** , _斜体_ , [リンク](url) 等）は、プレビュー上では簡易表示となりますが、Discord上では正しく反映されます。
            </p>
        </div>
    </div>
</div>

<script>
    function updatePreview() {
        const title = document.getElementById('embedTitle').value;
        const desc = document.getElementById('embedDesc').value;
        const color = document.getElementById('embedColor').value;
        const footer = document.getElementById('embedFooter').value;
        const image = document.getElementById('embedImage').value;

        document.getElementById('pvTitle').textContent = title || "Embed Title";
        document.getElementById('pvDesc').textContent = desc || "Your description will appear here...";
        document.getElementById('previewCard').style.borderColor = color;
        document.getElementById('pvFooter').textContent = footer || "";

        const pvImg = document.getElementById('pvImage');
        if (image) {
            pvImg.src = image;
            pvImg.style.display = "block";
        } else {
            pvImg.style.display = "none";
        }
    }

    // Initialization and Event Handling will be in dashboard.js
    if (window.initEmbedBuilder) window.initEmbedBuilder();
</script>