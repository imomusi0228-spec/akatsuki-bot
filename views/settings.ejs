                    </div>
                    <div>
                        <label class="muted" style="font-size:12px;">
                            <%= t("min_chars") %>
                        </label><br />
                        <input id="introMinChars" type="number" min="0" value="20" style="width:100%; margin-top:5px;">
                    </div>
                    <div>
                        <label class="muted" style="font-size:12px;">
                            <%= t("intro_ch_label") %>
                        </label><br />
                        <select id="introCh" style="width:100%; margin-top:5px;"></select>
                        <p class="muted" style="font-size:11px; margin-top:4px;">
                            <%= t("text_ch_only_notice") %>
                        </p>
                    </div>
                </div>

                <!-- Reminder -->
                <div style="margin-top:20px;">
                    <label class="muted" style="font-size:12px;">
                        <%= t("intro_reminder_label") %>
                    </label><br />
                    <input id="introReminder" type="number" min="0" value="0"
                        style="width:100%; max-width:200px; margin-top:5px;">
                    <p class="muted" style="font-size:11px; margin-top:4px;">
                        <%= t("disable_if_zero") %>
                    </p>
                </div>
            </div>
        </div>

        <script>
            document.addEventListener('DOMContentLoaded', async () => {

                if (typeof initSettings === 'function') {
                    initSettings();
                }

                const select = document.getElementById("introChannel");
                if (!select) return;

                select.innerHTML = '<option value="">読み込み中...</option>';

                try {
                    const res = await fetch("/api/guild/channels");
                    if (!res.ok) throw new Error("Failed");

                    const channels = await res.json();

                    select.innerHTML = '<option value="">選択してください</option>';

                    channels
                        .filter(ch => ch.type === 0)
                        .forEach(ch => {
                            const opt = document.createElement("option");
                            opt.value = ch.id;
                            opt.textContent = "# " + ch.name;
                            select.appendChild(opt);
                        });

                } catch (err) {
                    console.error("Channel loading error:", err);
                    select.innerHTML = '<option value="">読み込み失敗</option>';
                }

            });
        </script>

        <!-- 5. Channels -->
        <div class="accordion-item" id="sec-ch">
