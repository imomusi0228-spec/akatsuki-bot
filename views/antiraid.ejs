<style>
    .guard-selector {
        display: flex;
        gap: 20px;
        margin-bottom: 30px;
        justify-content: center;
    }

    .guard-card {
        flex: 1;
        padding: 20px;
        border-radius: 12px;
        border: 2px solid var(--border-color);
        text-align: center;
        cursor: pointer;
        transition: all 0.2s;
        background: rgba(255, 255, 255, 0.02);
        max-width: 250px;
    }

    .guard-card:hover {
        transform: translateY(-4px);
        background: rgba(255, 255, 255, 0.05);
    }

    .guard-card.active {
        border-color: var(--status-color);
        background: var(--status-bg);
        box-shadow: 0 0 20px var(--status-shadow);
    }

    .guard-icon {
        font-size: 32px;
        margin-bottom: 10px;
        display: block;
    }

    .guard-name {
        font-weight: bold;
        display: block;
        margin-bottom: 5px;
    }

    .guard-desc {
        font-size: 11px;
        color: var(--text-secondary);
        line-height: 1.4;
    }

    .guard-green {
        --status-color: #00ba7c;
        --status-bg: rgba(0, 186, 124, 0.1);
        --status-shadow: rgba(0, 186, 124, 0.2);
    }

    .guard-yellow {
        --status-color: #ffd400;
        --status-bg: rgba(255, 212, 0, 0.1);
        --status-shadow: rgba(255, 212, 0, 0.2);
    }

    .guard-red {
        --status-color: #f4212e;
        --status-bg: rgba(244, 33, 46, 0.1);
        --status-shadow: rgba(244, 33, 46, 0.2);
    }

    .accordion-item {
        border: 1px solid var(--border-color);
        border-radius: 8px;
        margin-bottom: 12px;
        background: rgba(255, 255, 255, 0.02);
    }

    .accordion-header {
        padding: 14px 20px;
        background: rgba(255, 255, 255, 0.03);
        cursor: pointer;
        display: flex;
        justify-content: space-between;
        align-items: center;
        font-weight: 600;
        transition: background 0.2s;
    }

    .accordion-header:hover {
        background: rgba(255, 255, 255, 0.07);
    }

    .accordion-content {
        padding: 20px;
        display: none;
        border-top: 1px solid var(--border-color);
        background: var(--card-bg);
    }

    .accordion-item.active .accordion-content {
        display: block;
    }

    .accordion-item.active .accordion-header {
        background: rgba(var(--accent-rgb), 0.15);
        color: var(--text-primary);
    }
</style>

<div class="card" style="max-width: 1000px;">
    <div style="display:flex; justify-content:space-between; align-items:center; margin-bottom:24px;">
        <h3 style="margin:0;">🛡️ <%= t("nav_antiraid") %>
        </h3>
        <span id="saveStatus" style="font-size:14px; font-weight:bold;"></span>
    </div>


    <!-- 2. Guard Mode Selector -->
    <div class="guard-selector">
        <div class="guard-card guard-green" id="guard-0" onclick="setGuard(0)">
            <span class="guard-icon">🟢</span>
            <span class="guard-name">
                <%= t("guard_mode_normal") %>
            </span>
            <span class="guard-desc">
                <%= t("guard_mode_normal_desc") %>
            </span>
        </div>
        <div class="guard-card guard-yellow" id="guard-1" onclick="setGuard(1)">
            <span class="guard-icon">🟡</span>
            <span class="guard-name">
                <%= t("guard_mode_caution") %>
            </span>
            <span class="guard-desc">
                <%= t("guard_mode_caution_desc") %>
            </span>
        </div>
        <div class="guard-card guard-red" id="guard-2" onclick="setGuard(2)">
            <span class="guard-icon">🔴</span>
            <span class="guard-name">
                <%= t("guard_mode_lockdown") %>
            </span>
            <span class="guard-desc">
                <%= t("guard_mode_lockdown_desc") %>
            </span>
        </div>
    </div>

    <div id="antiraid-settings" style="display: none;">
        <!-- 3. Rapid Join Detection -->
        <div class="accordion-item active" id="sec-rapid-join">
            <div class="accordion-header" onclick="toggleAccordion('sec-rapid-join')">
                <span>
                    <%= t("rapid_join_title") %><span class="help-tip" data-tip="<%= t('help_raid_join') %>">?</span>
                </span>
                <span>▼</span>
            </div>
            <div class="accordion-content">
                <div style="display:grid; grid-template-columns: 1fr 1fr; gap:20px;">
                    <div>
                        <label class="muted">
                            <%= t("raid_threshold_label") %>
                        </label>
                        <input id="raidThreshold" type="number" value="10" min="1" style="width:100%; margin-top:5px;">
                    </div>
                    <div>
                        <label class="muted">
                            <%= t("raid_action_label") %>
                        </label>
                        <select id="raidAction" style="width:100%; margin-top:5px;">
                            <option value="none">
                                <%= t("raid_action_warn") %>
                            </option>
                            <option value="caution">
                                <%= t("raid_action_caution") %>
                            </option>
                            <option value="lockdown">
                                <%= t("raid_action_lockdown") %>
                            </option>
                        </select>
                    </div>
                </div>
            </div>
        </div>

        <!-- 4. Newcomer Restrictions -->
        <div class="accordion-item" id="sec-newcomer">
            <div class="accordion-header" onclick="toggleAccordion('sec-newcomer')">
                <span>
                    <%= t("newcomer_restrict_title") %><span class="help-tip"
                            data-tip="<%= t('help_newcomer') %>">?</span>
                </span>
                <span>▼</span>
            </div>
            <div class="accordion-content">
                <div style="display:grid; grid-template-columns: 1fr 1fr; gap:20px;">
                    <div>
                        <label class="muted">
                            <%= t("newcomer_restrict_mins_label") %>
                        </label>
                        <input id="newcomerRestrictMins" type="number" value="10" min="0"
                            style="width:100%; margin-top:5px;">
                    </div>
                    <div>
                        <label class="muted">
                            <%= t("newcomer_account_age_label") %>
                        </label>
                        <input id="newcomerAccountAge" type="number" value="1" min="0"
                            style="width:100%; margin-top:5px;">
                    </div>
                </div>
                <p class="muted" style="margin-top:10px; font-size:11px;">
                    <%= t("newcomer_restrict_help") %>
                </p>
            </div>
        </div>

        <!-- 5. Link & Content Filter -->
        <div class="accordion-item" id="sec-filter">
            <div class="accordion-header" onclick="toggleAccordion('sec-filter')">
                <span>
                    <%= t("advanced_filter_title") %><span class="help-tip"
                            data-tip="<%= t('help_advanced_filter') %>">?</span>
                </span>
                <span>▼</span>
            </div>
            <div class="accordion-content">
                <div style="margin-bottom:15px;">
                    <label style="display:flex; align-items:center; cursor:pointer;">
                        <input type="checkbox" id="linkBlockEnabled"
                            style="width:18px; height:18px; margin-right:10px;">
                        <span>
                            <%= t("link_block_enabled_label") %>
                        </span>
                    </label>
                </div>
                <div>
                    <label class="muted">
                        <%= t("domain_blacklist_label") %>
                    </label>
                    <textarea id="domainBlacklist"
                        style="width:100%; min-height:60px; margin-top:5px; background:#000; color:#fff; border:1px solid var(--border-color); border-radius:6px; padding:10px;"></textarea>
                </div>
            </div>
        </div>

        <!-- 6. Iron Fortress II (v2.4.9) -->
        <div class="accordion-item" id="sec-advanced">
            <div class="accordion-header" onclick="toggleAccordion('sec-advanced')">
                <span>
                    <%= t("iron_fortress_title") %><span class="help-tip"
                            data-tip="<%= t('help_iron_fortress_desc') %>">?</span>
                </span>
                <span>▼</span>
            </div>
            <div class="accordion-content">
                <div style="margin-bottom:15px;">
                    <label style="display:flex; align-items:center; cursor:pointer;">
                        <input type="checkbox" id="antiraidAutoRecovery"
                            style="width:18px; height:18px; margin-right:10px;">
                        <span>
                            <%= t("auto_recovery_enabled_label") %>
                        </span>
                    </label>
                    <p class="muted" style="font-size:11px; margin-left:28px;">
                        <%= t("auto_recovery_help") %>
                    </p>
                </div>
                <div style="margin-bottom:15px;">
                    <label style="display:flex; align-items:center; cursor:pointer;">
                        <input type="checkbox" id="antiraidAvatarScrutiny"
                            style="width:18px; height:18px; margin-right:10px;">
                        <span>
                            <%= t("avatar_scrutiny_enabled_label") %>
                        </span>
                    </label>
                    <p class="muted" style="font-size:11px; margin-left:28px;">
                        <%= t("avatar_scrutiny_help") %>
                    </p>
                </div>
                <div>
                    <label class="muted">
                        <%= t("honeypot_channel_label") %>
                    </label>
                    <select id="antiraidHoneypotChannel" style="width:100%; margin-top:5px;">
                        <option value="">
                            <%= t("none") %>
                        </option>
                    </select>
                    <p class="muted" style="font-size:11px; margin-top:5px;">
                        <%= t("honeypot_help") %>
                    </p>
                </div>
            </div>
        </div>

        <!-- 7. Emergency Purge (v2.7.0) -->
        <div class="accordion-item" id="sec-purge">
            <div class="accordion-header" onclick="toggleAccordion('sec-purge')">
                <span>
                    <%= t("emergency_purge_title") %>
                </span>
                <span>▼</span>
            </div>
            <div class="accordion-content">
                <p class="muted" style="font-size:12px; margin-bottom:15px;">
                    <%= t("emergency_purge_desc") %>
                </p>
                <div style="display:flex; gap:15px; align-items:flex-end;">
                    <div style="flex:1;">
                        <label class="muted">
                            <%= t("purge_mins_label") %>
                        </label>
                        <input id="purgeMins" type="number" value="10" min="1" max="60"
                            style="width:100%; margin-top:5px;">
                    </div>
                </div>
                <button id="runPurge" class="btn btn-primary"
                    style="width:100%; margin-top:15px; background:#f4212e; border-color:#f4212e;">
                    <%= t("run_purge_btn") %>
                </button>
                <div id="purgeResult" class="muted" style="margin-top:10px; font-size:12px; text-align:center;"></div>
            </div>
        </div>

        <button id="save" class="btn btn-primary" style="width:100%; padding:15px; font-size:18px; margin-top:10px;">
            <%= t("save_fortress_btn") %>
        </button>
    </div>
</div>

<script>
    let currentGuardLevel = 0;
    function setGuard(level) {
        currentGuardLevel = level;
        document.querySelectorAll('.guard-card').forEach(c => c.classList.remove('active'));
        const el = document.getElementById('guard-' + level);
        if (el) el.classList.add('active');
    }

    // Standard Page Initialization
    async function initAntiRaid() {
        window.__pageReload = async () => {
            const gid = $("globalGuildSelect")?.value;
            if (!gid) return;
            document.getElementById('antiraid-settings').style.display = 'block';

            // Load Master Data
            const [st] = await Promise.all([
                api("/api/settings?guild=" + gid)
            ]);

            // Load Settings
            if (st.ok && st.settings) {
                const s = st.settings;
                await loadMasters(gid); // Ensure masters are loaded
                setGuard(s.antiraid_guard_level || 0);
                document.getElementById('raidThreshold').value = s.raid_join_threshold || 10;
                document.getElementById('newcomerRestrictMins').value = s.newcomer_restrict_mins || 10;
                document.getElementById('newcomerAccountAge').value = s.newcomer_min_account_age || 1;
                document.getElementById('linkBlockEnabled').checked = !!s.link_block_enabled;
                document.getElementById('domainBlacklist').value = (s.domain_blacklist || []).join(', ');

                // v2.4.9 Iron Fortress II
                document.getElementById('antiraidAutoRecovery').checked = !!s.antiraid_auto_recovery_enabled;
                document.getElementById('antiraidAvatarScrutiny').checked = !!s.antiraid_avatar_scrutiny_enabled;
                if (document.getElementById('antiraidHoneypotChannel')) {
                    document.getElementById('antiraidHoneypotChannel').value = s.antiraid_honeypot_channel_id || "";
                }
            }
        };

        if (!await loadGuilds()) return;
        window.__pageReload();

        document.getElementById('save').onclick = async () => {
            const gid = $("globalGuildSelect")?.value;
            if (!gid) return;
            const body = {
                guild: gid,
                antiraid_guard_level: currentGuardLevel,
                raid_join_threshold: parseInt(document.getElementById('raidThreshold').value),
                newcomer_restrict_mins: parseInt(document.getElementById('newcomerRestrictMins').value),
                newcomer_min_account_age: parseInt(document.getElementById('newcomerAccountAge').value),
                link_block_enabled: document.getElementById('linkBlockEnabled').checked,
                domain_blacklist: document.getElementById('domainBlacklist').value.split(',').map(s => s.trim()).filter(s => s),
                antiraid_auto_recovery_enabled: document.getElementById('antiraidAutoRecovery').checked,
                antiraid_avatar_scrutiny_enabled: document.getElementById('antiraidAvatarScrutiny').checked,
                antiraid_honeypot_channel_id: document.getElementById('antiraidHoneypotChannel').value || null
            };

            const res = await api("/api/settings/update", body);
            if (res.ok) {
                alert("<%= t('fortress_saved') %>");
                const statusEl = document.getElementById('saveStatus');
                if (statusEl) statusEl.textContent = "Saved";
            } else {
                alert("Error: " + res.error);
            }
        };

        // v2.7.0 Emergency Purge
        document.getElementById('runPurge').onclick = async () => {
            const gid = $("globalGuildSelect")?.value;
            const mins = parseInt(document.getElementById('purgeMins').value);
            if (!gid) return;
            if (!confirm("<%= t('purge_confirm', {mins: 'REPLACE_MINS'}) %>".replace('REPLACE_MINS', mins))) return;

            const btn = document.getElementById('runPurge');
            const resEl = document.getElementById('purgeResult');
            btn.disabled = true;
            btn.textContent = "<%= t('purging_dots') %>";
            resEl.textContent = "";

            const res = await api("/api/purge", { guild: gid, mins });
            btn.disabled = false;
            btn.textContent = "<%= t('run_purge_btn') %>";

            if (res.ok) {
                let msg = "<%= t('purge_success', {userCount: 'REPLACE_UC', deletedCount: 'REPLACE_DC'}) %>";
                msg = msg.replace('REPLACE_UC', res.userCount).replace('REPLACE_DC', res.deletedCount);
                resEl.innerHTML = `<span style="color:#00ba7c;">✅ ${msg}</span>`;
            } else {
                resEl.innerHTML = `<span style="color:#f4212e;">❌ Error: ${res.error}</span>`;
            }
        };
    }

    document.addEventListener('DOMContentLoaded', () => {
        if (typeof initAntiRaid === 'function') initAntiRaid();
    });
</script>