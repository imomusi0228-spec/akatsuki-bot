<style>
    .accordion-item {
        border: 1px solid var(--border-color);
        border-radius: 8px;
        margin-bottom: 12px;
        background: rgba(255, 255, 255, 0.02);
    }

    .accordion-header {
        padding: 14px 20px;
        background: rgba(255, 255, 255, 0.03);
        cursor: pointer;
        display: flex;
        justify-content: space-between;
        align-items: center;
        font-weight: 600;
        transition: background 0.2s;
    }

    .accordion-header:hover {
        background: rgba(255, 255, 255, 0.07);
    }

    .accordion-content {
        padding: 20px;
        display: none;
        border-top: 1px solid var(--border-color);
        background: var(--card-bg);
    }

    .accordion-item.active .accordion-content {
        display: block;
    }

    .accordion-item.active .accordion-header {
        background: rgba(29, 155, 240, 0.1);
        color: var(--accent-color);
    }

    .ng-item {
        display: inline-flex;
        align-items: center;
        background: rgba(244, 33, 46, 0.1);
        color: #f4212e;
        border: 1px solid rgba(244, 33, 46, 0.2);
        padding: 4px 12px;
        border-radius: 20px;
        margin: 4px;
        font-size: 13px;
    }

    .ng-item button {
        background: none;
        border: none;
        color: #f4212e;
        margin-left: 8px;
        cursor: pointer;
        font-weight: bold;
        padding: 0 4px;
    }

    .help-icon {
        color: var(--text-secondary);
        cursor: help;
        font-size: 14px;
        margin-left: 6px;
    }
</style>

<div class="card" style="max-width: 1000px;">
    <div style="display:flex; justify-content:space-between; align-items:center; margin-bottom:20px;">
        <h3 style="margin:0;">
            <%= t("settings") %>
        </h3>
        <span id="saveStatus" style="font-size:14px; font-weight:bold;"></span>
    </div>

    <!-- 1. Server Selector -->
    <div class="setting-section" style="margin-bottom:24px;">
        <label class="muted">Select Server</label>
        <div style="display:flex; gap:10px; align-items:center; margin-top:8px;">
            <select id="guild" style="flex:1;"></select>
            <button id="reload" class="btn">Reload</button>
        </div>
        <div id="guildStatus" style="font-size:12px; margin-top:4px;"></div>
    </div>

    <!-- ACCORDION START -->
    <div id="settings-accordion">

        <!-- 2. NG Words -->
        <div class="accordion-item active" id="sec-ng">
            <div class="accordion-header" onclick="toggleAccordion('sec-ng')">
                <span>🚫 <%= t("feature_ng_limit") %><span class="help-tip"
                            data-tip="<%= t('help_ng_limit') %>">?</span> <span id="ngCount" class="muted"
                            style="margin-left:10px; font-weight: normal;">0 <%= t("words") %></span></span>
                <span>▼</span>
            </div>
            <div class="accordion-content">
                <div style="display:flex; gap:10px; margin-bottom:15px;">
                    <input id="newWord" type="text" placeholder="Add word..." style="flex:1;">
                    <button onclick="addNg()" class="btn btn-primary">+</button>
                </div>
                <div id="ngList" style="background:rgba(0,0,0,0.2); border-radius:8px; padding:10px; min-height:60px;">
                </div>
                <p class="muted" style="margin-top:10px; font-size:11px; margin-bottom: 20px;">※スラッシュで囲むと正規表現として扱われます
                    (例: /badword/i)</p>

                <!-- Moved: Phase Escalation Settings -->
                <div style="border-top:1px solid var(--border-color); padding-top:20px; margin-top:18px;">
                    <div style="display:flex; align-items:center; justify-content:space-between; margin-bottom:15px;">
                        <label class="muted" style="margin:0;">⚠️ 段階制裁設定（NGワード自動エスカレーション）</label>
                        <label style="display:flex; align-items:center; cursor:pointer; font-size:12px;">
                            <input type="checkbox" id="ngWarningEnabled" checked
                                style="width:16px; height:16px; margin-right:8px;">
                            <span>
                                <%= t("ng_warning_enabled") %>
                            </span>
                        </label>
                    </div>
                    <div style="display:grid; grid-template-columns: 1fr 1fr 1fr; gap:15px;">
                        <div>
                            <label class="muted" style="font-size:12px;">フェーズ2：違反N回以上</label><br />
                            <input id="phase2Threshold" type="number" min="1" value="3"
                                style="width:100%; margin-top:5px;">
                            <select id="phase2Action" style="width:100%; margin-top:5px;">
                                <option value="timeout">タイムアウト</option>
                                <option value="kick">キック</option>
                                <option value="ban">BAN</option>
                            </select>
                        </div>
                        <div>
                            <label class="muted" style="font-size:12px;">フェーズ3：違反N回以上</label><br />
                            <input id="phase3Threshold" type="number" min="1" value="6"
                                style="width:100%; margin-top:5px;">
                            <select id="phase3Action" style="width:100%; margin-top:5px;">
                                <option value="timeout">タイムアウト</option>
                                <option value="kick">キック</option>
                                <option value="ban">BAN</option>
                            </select>
                        </div>
                        <div>
                            <label class="muted" style="font-size:12px;">フェーズ4：違反N回以上</label><br />
                            <input id="phase4Threshold" type="number" min="1" value="10"
                                style="width:100%; margin-top:5px;">
                            <select id="phase4Action" style="width:100%; margin-top:5px;">
                                <option value="timeout">タイムアウト</option>
                                <option value="kick">キック</option>
                                <option value="ban">BAN</option>
                            </select>
                        </div>
                    </div>
                    <p class="muted" style="font-size:11px; margin-top:8px;">※ 過去1時間のNG違反回数が各しきい値に達すると選択したアクションが実行されます。
                    </p>
                </div>
            </div>
        </div>

        <!-- 3. Anti-Raid -->
        <div class="accordion-item" id="sec-raid">
            <div class="accordion-header" onclick="toggleAccordion('sec-raid')">
                <span>🛡️ <%= t("anti_raid_settings") %><span class="help-tip"
                            data-tip="<%= t('help_antiraid') %>">?</span></span>
                <span>▼</span>
            </div>
            <div class="accordion-content">
                <div style="margin-bottom:15px;">
                    <label style="display:flex; align-items:center; cursor:pointer;">
                        <input type="checkbox" id="antiraidEnabled" style="width:18px; height:18px; margin-right:10px;">
                        <span style="font-weight: bold;">アンチ・レイド保護を有効化</span>
                    </label>
                </div>
                <div>
                    <label class="muted">
                        <%= t("antiraid_threshold") %>
                    </label><br />
                    <input id="antiraidThreshold" type="number" min="1" max="1000"
                        style="width:100%; max-width: 300px; margin-top:5px;">
                </div>
            </div>
        </div>
    </div>

    <!-- 4. Self Introduction Gate -->
    <div class="accordion-item" id="sec-intro">
        <div class="accordion-header" onclick="toggleAccordion('sec-intro')">
            <span>📝 <%= t("roadmap_introgate") %><span class="help-tip"
                        data-tip="<%= t('help_introgate') %>">?</span></span>
            <span>▼</span>
        </div>
        <div class="accordion-content">
            <div style="margin-bottom:15px;">
                <label style="display:flex; align-items:center; cursor:pointer;">
                    <input type="checkbox" id="introGateEnabled" style="width:18px; height:18px; margin-right:10px;">
                    <span>自己紹介ゲートを有効化</span>
                </label>
            </div>
            <div style="display:grid; grid-template-columns: 1fr 1fr; gap:20px;">
                <div>
                    <label class="muted">付与するロール</label><br />
                    <select id="introRole" style="width:100%; margin-top:5px;"></select>
                </div>
                <div>
                    <label class="muted">必要最小文字数</label><br />
                    <input id="introMinLen" type="number" min="1" value="10" style="width:100%; margin-top:5px;">
                </div>
            </div>
            <div style="margin-top:15px;">
                <label class="muted">📬 未投稿リマインダー (参加からN時間後にDM送信)</label><br />
                <input id="introReminderHours" type="number" min="1" max="720" value="24"
                    style="width:100%; max-width:200px; margin-top:5px;">
                <p class="muted" style="font-size:11px; margin-top:5px;">※
                    自己紹介チャンネルにまだ投稿していないメンバーへ自動でDMを送ります。0に設定すると無効になります。</p>
            </div>
        </div>
    </div>

    <!-- 5. Channels -->
    <div class="accordion-item" id="sec-ch">
        <div class="accordion-header" onclick="toggleAccordion('sec-ch')">
            <span>📢 <%= t("log_settings") %></span>
            <span>▼</span>
        </div>
        <div class="accordion-content">
            <div style="display:grid; grid-template-columns: 1fr 1fr; gap:20px;">
                <div>
                    <label class="muted">
                        <%= t("vc_log_ch") %>
                    </label><br />
                    <select id="logCh" style="width:100%; margin-top:5px;"></select>
                </div>
                <div>
                    <label class="muted">
                        <%= t("ng_log_ch") %>
                    </label><br />
                    <select id="ngLogCh" style="width:100%; margin-top:5px;"></select>
                </div>
            </div>
            <div style="margin-top:15px;">
                <label class="muted">📬 /report 報告の送信先チャンネル（専用）</label><br />
                <select id="reportCh" style="width:100%; max-width:400px; margin-top:5px;"></select>
                <p class="muted" style="font-size:11px; margin-top:5px;">※ 未設定の場合はNGログチャンネルに報告が送信されます。</p>
            </div>
        </div>
    </div>

    <!-- 6. VC Related (Roles & Reports) -->
    <div class="accordion-item" id="sec-vc">
        <div class="accordion-header" onclick="toggleAccordion('sec-vc')">
            <span>🎤 VC高度設定 (Roles & Reports)</span>
            <span>▼</span>
        </div>
        <div class="accordion-content">
            <!-- Role Rules -->
            <div style="margin-bottom:24px;">
                <label class="muted" style="display:block; margin-bottom:10px;">VC活動時間に応じたオーラ付与（名称と時間）<span
                        class="help-tip" data-tip="<%= t('help_vc_role') %>">?</span></label>
                <div id="roleRulesList" style="display:flex; flex-direction:column; gap:8px; margin-bottom:10px;">
                </div>
                <button type="button" onclick="addRoleRule()" class="btn" style="font-size:12px; width:100%;">+
                    オーラを追加</button>

            </div>

            <!-- Reports -->
            <div style="border-top:1px solid var(--border-color); padding-top:20px;">
                <label style="display:flex; align-items:center; cursor:pointer; margin-bottom:15px;">
                    <input type="checkbox" id="vcReportEnabled" style="width:18px; height:18px; margin-right:10px;">
                    <span>VCアクティビティ週報を有効化<span class="help-tip" data-tip="<%= t('help_vc_report') %>">?</span></span>
                </label>
                <div style="display:grid; grid-template-columns: 1fr 1fr; gap:20px;">
                    <div>
                        <label class="muted">レポート送信先</label><br />
                        <select id="vcReportCh" style="width:100%; margin-top:5px;"></select>
                    </div>
                    <div>
                        <label class="muted">送信間隔</label><br />
                        <select id="vcReportInterval" style="width:100%; margin-top:5px;">
                            <option value="daily">毎日</option>
                            <option value="weekly" selected>毎週</option>
                            <option value="monthly">毎月</option>
                        </select>
                    </div>
                </div>
            </div>

            <!-- Dynamic VC (Auto-VC) -->
            <div style="border-top:1px solid var(--border-color); padding-top:20px; margin-top:20px;">
                <label class="muted">📂 Auto-VC 対象カテゴリ<span class="help-tip"
                        data-tip="指定したカテゴリ内の最上位チャンネルに入ると、自分専用のVCが自動生成されます。">?</span></label><br />
                <select id="autoVcCategory" style="width:100%; max-width:400px; margin-top:5px;"></select>
                <p class="muted" style="font-size:11px; margin-top:5px;">※ カテゴリ内の最上位VCに入室時に作成、退出時（0人時）に削除されます。</p>
            </div>
        </div>
    </div>

    <!-- 7-9. AI Analysis & Insights (Combined) -->
    <div class="accordion-item" id="sec-ai-all">
        <div class="accordion-header" onclick="toggleAccordion('sec-ai-all')">
            <span>🤖 AI 分析 & インサイト</span>
            <span>▼</span>
        </div>
        <div class="accordion-content">

            <!-- --- コミュニティ・ヘルス・レーダー --- -->
            <div style="margin-bottom:24px; padding-bottom:24px; border-bottom:1px solid var(--border-color);">
                <h5 style="margin:0 0 12px 0; color:var(--accent-color); font-size:13px;">🤖 コミュニティ・ヘルス・レーダー (AIアドバイス)
                    <span class="help-tip" data-tip="<%= t('help_ai_advice') %>">?</span>
                </h5>
                <div style="display:grid; grid-template-columns: 1fr 1fr; gap:20px;">
                    <div>
                        <label class="muted">アドバイスを行う放置日数</label><br />
                        <input id="aiAdviceDays" type="number" min="1" value="14" style="width:100%; margin-top:5px;">
                    </div>
                    <div>
                        <label class="muted">アドバイス通知先</label><br />
                        <select id="aiAdviceCh" style="width:100%; margin-top:5px;"></select>
                    </div>
                </div>
            </div>

            <!-- --- サーバー・インサイト --- -->
            <div style="margin-bottom:24px; padding-bottom:24px; border-bottom:1px solid var(--border-color);">
                <h5 style="margin:0 0 12px 0; color:var(--accent-color); font-size:13px;">🏯 サーバー・インサイト (運営アドバイス) <span
                        class="help-tip" data-tip="<%= t('help_ai_insight') %>">?</span></h5>
                <div style="margin-bottom:15px;">
                    <label style="display:flex; align-items:center; cursor:pointer;">
                        <input type="checkbox" id="aiInsightEnabled"
                            style="width:18px; height:18px; margin-right:10px;">
                        <span>運営アドバイス機能を有効化</span>
                    </label>
                </div>
                <div style="display:grid; grid-template-columns: 1fr 1fr; gap:20px; margin-bottom:20px;">
                    <div>
                        <label class="muted">アドバイス配信先 (管理者推奨)</label><br />
                        <select id="aiInsightCh" style="width:100%; margin-top:5px;"></select>
                    </div>
                </div>
                <div style="border-top: 1px solid var(--border-color); padding-top:15px;">
                    <label class="muted" style="margin-bottom:10px; display:block;">&#128203; 配信セクションの選択</label>
                    <div style="display:flex; flex-direction:column; gap:10px;">
                        <label style="display:flex; align-items:center; cursor:pointer; gap:10px;">
                            <input type="checkbox" id="insightGrowth" style="width:16px; height:16px;">
                            <span>📈 メンバー増減（成長分析）</span>
                        </label>
                        <label style="display:flex; align-items:center; cursor:pointer; gap:10px;">
                            <input type="checkbox" id="insightToxicity" style="width:16px; height:16px;">
                            <span>🚫 NGワード検知数（秩序分析）</span>
                        </label>
                        <label style="display:flex; align-items:center; cursor:pointer; gap:10px;">
                            <input type="checkbox" id="insightVc" style="width:16px; height:16px;">
                            <span>🎤 VC利用者数（活性化分析）</span>
                        </label>
                    </div>
                    <p class="muted" style="margin-top:10px; font-size:11px;">
                        ※チェックを外したセクションはレポートに含まれません。全て無効ではレポート自体が送信されません。</p>
                </div>
            </div>

            <!-- --- AI 予兆検知 --- -->
            <div>
                <h5 style="margin:0 0 12px 0; color:var(--accent-color); font-size:13px;">🧠 AI 予兆検知 (Atmosphere
                    Insight)</h5>
                <div style="margin-bottom:15px;">
                    <label style="display:flex; align-items:center; cursor:pointer;">
                        <input type="checkbox" id="aiPredictionEnabled"
                            style="width:18px; height:18px; margin-right:10px;">
                        <span style="font-weight: bold;">不穏な空気の予兆検知を有効化</span>
                    </label>
                    <p class="muted" style="font-size:12px; margin-top:8px;">
                        メッセージの密度やNGワードの頻度をAIがリアルタイムに分析し、トラブルが起きそうな不穏な空気を察知すると、運営レポート用チャンネルにアラートを送信します。
                    </p>
                </div>
            </div>

        </div>
    </div>


</div>
</div>

<!-- ACCORDION END -->



<div style="margin-top:30px; display:flex; gap:15px;">
    <button id="save" class="btn btn-primary" style="flex:1; padding:12px; font-size:16px;">
        <%= t("save_settings") %>
    </button>
</div>
</div>

<script>initSettings();</script>