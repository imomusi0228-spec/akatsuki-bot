<div class="card" style="max-width: 1100px;">
    <div style="display:flex; justify-content:space-between; align-items:center; margin-bottom:20px;">
        <h3 style="margin:0;">🎫 チケット管理 ＆ 設定</h3>
        <div style="display:flex; gap:10px;">
            <select id="statusFilter" style="font-size:12px;">
                <option value="all">すべて</option>
                <option value="open" selected>進行中</option>
                <option value="closed">解決済</option>
            </select>
            <button id="refreshTickets" class="btn btn-primary" style="padding:4px 12px; font-size:12px;">更新</button>
        </div>
    </div>


    <!-- 2. Ticket Settings (Consolidated from main settings) -->
    <div class="setting-section"
        style="margin-bottom:24px; background:rgba(255,255,255,0.02); padding:20px; border-radius:8px; border:1px solid var(--border-color);">
        <h4
            style="margin-top:0; margin-bottom:15px; font-size:14px; color:var(--text-primary); border-left: 4px solid var(--accent-color); padding-left: 10px;">
            ⚙️ チケット基本設定</h4>
        <div style="margin-bottom:20px;">
            <label class="muted" style="font-size:12px;">🛡️ モデレーターロール（対応可能なスタッフ）</label><br />
            <select id="ticketStaffRole" style="width:100%; margin-top:8px; padding:10px; border-radius:8px;">
                <option value="">ロード中...</option>
            </select>
            <p class="muted" style="font-size:11px; margin-top:8px;">※ ここで設定したロールを持つメンバーを、チケットの担当者として割り当てることができます。</p>
        </div>
        <div style="margin-bottom:20px;">
            <label class="muted" style="font-size:12px;">📜 チケットログ送信先チャンネル</label><br />
            <select id="ticketLogCh" style="width:100%; margin-top:8px; padding:10px; border-radius:8px;">
                <option value="">ロード中...</option>
            </select>
            <p class="muted" style="font-size:11px; margin-top:8px;">※ チケットがクローズされた際に、会話履歴（HTML）がこのチャンネルに送信されます。</p>
        </div>
        <div style="margin-bottom:20px;">
            <label class="muted" style="font-size:12px;">📦 チケット作成時の初期メッセージ（お嬢の言葉）</label><br />
            <textarea id="ticketWelcomeMsg"
                style="width:100%; height:80px; margin-top:8px; padding:12px; border-radius:8px; border:1px solid var(--border-color); background:rgba(0,0,0,0.2); color:white; font-size:13px;"
                placeholder="スタッフが対応するまで、相談内容を記入してお待ちください..."></textarea>
            <p class="muted" style="font-size:11px; margin-top:8px;">※ 空欄の場合はボット標準のメッセージが使用されます。</p>
        </div>
        <div style="display:flex; justify-content:flex-end; gap:10px; align-items:center;">
            <span id="saveStatus" style="font-size:12px;"></span>
            <button id="saveTicketSettings" class="btn btn-primary"
                style="padding:6px 20px; font-size:13px;">設定を保存</button>
        </div>
    </div>

    <div style="overflow-x: auto;">
        <table style="width:100%; min-width:800px;">
            <thead>
                <tr>
                    <th style="width:80px;">ID</th>
                    <th>起票者</th>
                    <th>担当スタッフ</th>
                    <th style="width:120px;">ステータス</th>
                    <th style="width:180px;">作成日時</th>
                    <th style="width:160px; text-align:right;">アクション</th>
                </tr>
            </thead>
            <tbody id="ticketList">
                <tr>
                    <td colspan="6" class="muted" style="text-align:center; padding:30px;">
                        <%= t("loading") %>...
                    </td>
                </tr>
            </tbody>
        </table>
    </div>
</div>

<!-- Assign Member Modal -->
<div id="assignModal"
    style="display:none; position:fixed; top:0; left:0; width:100%; height:100%; background:rgba(0,0,0,0.8); z-index:10000; justify-content:center; align-items:center; padding:20px;">
    <div class="card"
        style="width:100%; max-width:400px; padding:20px; border:1px solid var(--accent-color); position:relative;">
        <h4 style="margin-top:0; color:var(--accent-color);">👥 担当をアサイン</h4>
        <p class="muted" style="font-size:12px; margin-bottom:15px;">このチケットを担当するモデレーターを選択してください。</p>
        <div id="memberList"
            style="max-height:300px; overflow-y:auto; margin-bottom:20px; display:flex; flex-direction:column; gap:8px;">
            <!-- Members will be loaded here -->
        </div>
        <div style="display:flex; justify-content:flex-end;">
            <button onclick="$('assignModal').style.display='none'" class="btn"
                style="padding:4px 12px; font-size:12px;">キャンセル</button>
        </div>
    </div>
</div>

<style>
    .status-badge {
        padding: 4px 10px;
        border-radius: 20px;
        font-size: 11px;
        font-weight: bold;
        text-transform: uppercase;
    }

    .status-open {
        background: rgba(0, 186, 124, 0.1);
        color: #00ba7c;
        border: 1px solid rgba(0, 186, 124, 0.2);
    }

    .status-closed {
        background: rgba(139, 155, 180, 0.1);
        color: #8b9bb4;
        border: 1px solid rgba(139, 155, 180, 0.2);
    }

    .staff-assign-btn {
        background: rgba(var(--accent-rgb), 0.1);
        color: var(--accent-color);
        border: 1px solid var(--accent-color);
        padding: 4px 10px;
        border-radius: 4px;
        font-size: 11px;
        cursor: pointer;
        transition: all 0.2s;
        margin-right: 5px;
    }

    .staff-assign-btn:hover {
        background: var(--accent-color);
        color: white;
    }

    .member-item {
        display: flex;
        align-items: center;
        gap: 12px;
        padding: 10px;
        background: rgba(255, 255, 255, 0.03);
        border-radius: 8px;
        cursor: pointer;
        transition: all 0.2s;
        border: 1px solid transparent;
    }

    .member-item:hover {
        background: rgba(var(--accent-rgb), 0.1);
        border-color: var(--accent-color);
    }

    .member-item img {
        width: 32px;
        height: 32px;
        border-radius: 50%;
    }

    .btn-delete {
        padding: 2px 8px;
        font-size: 11px;
        background: rgba(244, 33, 46, 0.1);
        color: #f4212e;
        border: 1px solid rgba(244, 33, 46, 0.3);
        border-radius: 4px;
        cursor: pointer;
        transition: all 0.2s;
    }

    .btn-delete:hover {
        background: #f4212e;
        color: white;
    }
</style>

<script>
document.addEventListener('DOMContentLoaded', () => {
    initTicketsPage();
});

async function initTicketsPage() {
    loadTickets();

    document.getElementById("refreshTickets")
        .addEventListener("click", loadTickets);

    document.getElementById("statusFilter")
        .addEventListener("change", loadTickets);
}

async function loadTickets() {
    const tbody = document.getElementById("ticketList");
    const status = document.getElementById("statusFilter").value;

    tbody.innerHTML = `
        <tr>
            <td colspan="6" style="text-align:center; padding:20px;">
                読み込み中...
            </td>
        </tr>
    `;

    try {
        const res = await fetch("/api/tickets");
        const tickets = await res.json();

        const filtered = status === "all"
            ? tickets
            : tickets.filter(t => t.status === status);

        if (!filtered.length) {
            tbody.innerHTML = `
                <tr>
                    <td colspan="6" style="text-align:center; padding:20px;">
                        チケットはありません。
                    </td>
                </tr>
            `;
            return;
        }

        tbody.innerHTML = "";

        filtered.forEach(t => {
            const tr = document.createElement("tr");

            const logBtn = t.transcript_id
                ? `<a href="/transcripts/${t.transcript_id}.html" target="_blank" class="staff-assign-btn">📄 ログ</a>`
                : "";

            tr.innerHTML = `
                <td>${t.id}</td>
                <td>${t.user_id}</td>
                <td>${t.assigned_to || "未割当"}</td>
                <td>
                    <span class="status-badge status-${t.status}">
                        ${t.status}
                    </span>
                </td>
                <td>${new Date(t.created_at).toLocaleString("ja-JP")}</td>
                <td style="text-align:right;">
                    ${logBtn}
                </td>
            `;

            tbody.appendChild(tr);
        });

    } catch (err) {
        tbody.innerHTML = `
            <tr>
                <td colspan="6" style="text-align:center; padding:20px;">
                    読み込み失敗
                </td>
            </tr>
        `;
        console.error(err);
    }
}
</script>