                    <label
                        style="display:flex; align-items:center; gap:8px; cursor:pointer; padding:8px; background:rgba(255,255,255,0.03); border-radius:6px;">
                        <input type="checkbox" id="mlChCreate"> <span style="font-size:13px;">📂 <%= t("log_ch_create")
                                %></span>
                    </label>
                    <label
                        style="display:flex; align-items:center; gap:8px; cursor:pointer; padding:8px; background:rgba(255,255,255,0.03); border-radius:6px;">
                        <input type="checkbox" id="mlChDelete"> <span style="font-size:13px;">🗑️ <%= t("log_ch_delete")
                                %></span>
                    </label>
                    <label
                        style="display:flex; align-items:center; gap:8px; cursor:pointer; padding:8px; background:rgba(255,255,255,0.03); border-radius:6px;">
                        <input type="checkbox" id="mlMsgEdit"> <span style="font-size:13px;">✏️ <%= t("log_msg_edit") %>
                        </span>
                    </label>
                    <label
                        style="display:flex; align-items:center; gap:8px; cursor:pointer; padding:8px; background:rgba(255,255,255,0.03); border-radius:6px;">
                        <input type="checkbox" id="mlMsgDelete"> <span style="font-size:13px;">🗑️ <%=
                                t("log_msg_delete") %></span>
