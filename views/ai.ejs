<style>
    .accordion-item {
        border: 1px solid var(--border-color);
        border-radius: 8px;
        margin-bottom: 12px;
        background: rgba(255, 255, 255, 0.02);
    }

    .accordion-header {
        padding: 14px 20px;
        background: rgba(255, 255, 255, 0.03);
        cursor: pointer;
        display: flex;
        justify-content: space-between;
        align-items: center;
        font-weight: 600;
        transition: background 0.2s;
    }

    .accordion-header:hover {
        background: rgba(255, 255, 255, 0.07);
    }

    .accordion-content {
        padding: 20px;
        display: none;
        border-top: 1px solid var(--border-color);
        background: var(--card-bg);
    }

    .accordion-item.active .accordion-content {
        display: block;
    }

    .accordion-item.active .accordion-header {
        background: rgba(var(--accent-rgb), 0.15);
        color: var(--text-primary);
    }

    .help-icon {
        color: var(--text-secondary);
        cursor: help;
        font-size: 14px;
        margin-left: 6px;
    }
</style>

<div class="card" style="max-width: 1000px;">
    <div style="display:flex; justify-content:space-between; align-items:center; margin-bottom:20px;">
        <h3 style="margin:0;">
            <%= t("ai_insight_title") %>
        </h3>
        <span id="saveStatus" style="font-size:14px; font-weight:bold;"></span>
    </div>


    <!-- ACCORDION START -->
    <div id="ai-accordion">

        <!-- 1. コミュニティ・ヘルス・レーダー -->
        <div class="accordion-item active" id="sec-ai">
            <div class="accordion-header" onclick="toggleAccordion('sec-ai')">
                <span>
                    <%= t("ai_radar_title") %> <span class="help-tip" data-tip="<%= t('help_ai_advice') %>">?</span>
                </span>
                <span>▼</span>
            </div>
            <div class="accordion-content">
                <div style="display:grid; grid-template-columns: 1fr 1fr; gap:20px;">
                    <div>
                        <label class="muted">
                            <%= t("ai_advice_days_label") %>
                        </label><br />
                        <input id="aiAdviceDays" type="number" min="1" value="14" style="width:100%; margin-top:5px;">
                    </div>
                    <div>
                        <label class="muted">
                            <%= t("ai_advice_ch_label") %>
                        </label><br />
                        <select id="aiAdviceCh" style="width:100%; margin-top:5px;"></select>
                    </div>
                </div>
            </div>
        </div>

        <!-- 2. サーバー・インサイト -->
        <div class="accordion-item" id="sec-insight">
            <div class="accordion-header" onclick="toggleAccordion('sec-insight')">
                <span>
                    <%= t("server_insight_title") %> <span class="help-tip"
                            data-tip="<%= t('help_ai_insight') %>">?</span>
                </span>
                <span>▼</span>
            </div>
            <div class="accordion-content">
                <div style="margin-bottom:15px;">
                    <label style="display:flex; align-items:center; cursor:pointer;">
                        <input type="checkbox" id="aiInsightEnabled"
                            style="width:18px; height:18px; margin-right:10px;">
                        <span>
                            <%= t("ai_insight_enabled_label") %>
                        </span>
                    </label>
                </div>
                <div style="display:grid; grid-template-columns: 1fr 1fr; gap:20px; margin-bottom:20px;">
                    <div>
                        <label class="muted">
                            <%= t("ai_insight_ch_label_admin") %>
                        </label><br />
                        <select id="aiInsightCh" style="width:100%; margin-top:5px;"></select>
                    </div>
                </div>

                <div style="border-top: 1px solid var(--border-color); padding-top:15px;">
                    <label class="muted" style="margin-bottom:10px; display:block;">
                        <%= t("insight_sections_title") %>
                    </label>
                    <div style="display:flex; flex-direction:column; gap:10px;">
                        <label style="display:flex; align-items:center; cursor:pointer; gap:10px;">
                            <input type="checkbox" id="insightGrowth" style="width:16px; height:16px;">
                            <span>📈 <%= t("growth_trend") %></span>
                        </label>
                        <label style="display:flex; align-items:center; cursor:pointer; gap:10px;">
                            <input type="checkbox" id="insightToxicity" style="width:16px; height:16px;">
                            <span>🚫 <%= t("section_toxicity_label") %></span>
                        </label>
                        <label style="display:flex; align-items:center; cursor:pointer; gap:10px;">
                            <input type="checkbox" id="insightVc" style="width:16px; height:16px;">
                            <span>🎤 <%= t("section_vc_label") %></span>
                        </label>
                    </div>
                    <p class="muted" style="margin-top:10px; font-size:11px;">
                        <%= t("insight_sections_help") %>
                    </p>
                </div>
            </div>
        </div>

        <!-- 3. AI 予兆検知 -->
        <div class="accordion-item" id="sec-aipredict">
            <div class="accordion-header" onclick="toggleAccordion('sec-aipredict')">
                <span>
                    <%= t("atmosphere_insight_title") %>
                </span>
                <span>▼</span>
            </div>
            <div class="accordion-content">
                <div style="margin-bottom:15px;">
                    <label style="display:flex; align-items:center; cursor:pointer;">
                        <input type="checkbox" id="aiPredictionEnabled"
                            style="width:18px; height:18px; margin-right:10px;">
                        <span style="font-weight: bold;">
                            <%= t("ai_prediction_enabled_label") %>
                        </span>
                    </label>
                    <p class="muted" style="font-size:12px; margin-top:8px;">
                        <%= t("ai_prediction_desc") %>
                    </p>
                </div>
                <div style="margin-top:15px;">
                    <label class="muted">
                        <%= t("ai_predict_ch_label") %>
                    </label><br />
                    <select id="aiPredictCh" style="width:100%; max-width:400px; margin-top:5px;"></select>
                </div>
                <div style="margin-top:15px;">
                    <label class="muted">
                        <%= t("ai_slowmode_restore_label") || "自動復旧時間 (分)" %>
                    </label><br />
                    <select id="aiSlowmodeRestore" style="width:100%; max-width:100px; margin-top:5px;">
                        <option value="1">1</option>
                        <option value="3">3</option>
                        <option value="5" selected>5</option>
                        <option value="10">10</option>
                        <option value="15">15</option>
                        <option value="30">30</option>
                    </select>
                    <span class="muted" style="font-size: 12px; margin-left: 5px;">min</span>
                </div>
            </div>
        </div>

    </div>
    <!-- ACCORDION END -->

    <div style="margin-top:30px; display:flex; gap:15px;">
        <button id="saveAi" class="btn btn-primary" style="flex:1; padding:12px; font-size:16px;">
            <%= t("save_settings") %>
        </button>
    </div>
</div>

<script>
    document.addEventListener('DOMContentLoaded', () => {
        if (typeof initAiPage === 'function') initAiPage();
    });
</script>