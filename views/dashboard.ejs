<div style="max-width: 1000px; margin: 0 auto 20px auto;">
    <!-- Dashboard Top Bar: Month selector and Plan info -->
    <div class="card"
        style="padding: 12px 20px; margin-bottom: 20px; display: flex; align-items: center; justify-content: space-between; flex-wrap: wrap; gap: 15px; background: rgba(var(--accent-rgb), 0.03); border: 1px solid rgba(var(--accent-rgb), 0.1);">
        <div style="display: flex; align-items: center; gap: 10px;">
            <label for="month" class="muted"
                style="font-size: 11px; font-weight: bold; text-transform: uppercase; letter-spacing: 0.05em;">📅
                表示月指定</label>
            <input id="month" type="month"
                style="padding: 6px 12px; font-size: 13px; border-radius: 6px; border: 1px solid var(--border-color); background: rgba(0,0,0,0.3); color: white; outline: none;" />
        </div>

        <div style="display: flex; align-items: center; gap: 15px;">
            <div style="text-align: right;">
                <div class="muted" style="font-size: 10px; text-transform: uppercase;">
                    <%= t("plan_label") %>
                </div>
                <div id="plan-info"
                    style="font-size: 14px; font-weight: 800; color: var(--accent-color); text-shadow: 0 0 10px rgba(var(--accent-rgb), 0.3);">
                    ...</div>
            </div>
            <!-- Reload button is removed as per user request (Duplicate of global reload) -->
        </div>
    </div>

    <div
        style="display:grid; grid-template-columns: repeat(auto-fit, minmax(320px, 1fr)); gap:15px; margin-bottom:15px; max-width: 1000px; margin-left: auto; margin-right: auto; align-items: start;">
        <!-- Chart 1: Growth -->
        <div class="card" style="padding:10px; margin-bottom:0; min-height:200px;">
            <h4
                style="margin:0 0 12px 0; font-size:12px; font-weight:bold; color:var(--text-primary); border-bottom: 2px solid var(--accent-color); padding-bottom: 4px;">
                <span>📈 <%= t("growth_trend")%></span>
            </h4>
            <div style="height:150px;"><canvas id="growthChart"></canvas></div>
        </div>

        <!-- Stats Grid: Re-integrated between charts -->
        <div id="stats-grid" class="card"
            style="padding: 12px; margin-bottom: 0; min-height:200px; display:flex; flex-direction:column; justify-content:center;">
            <div style="display: grid; grid-template-columns: repeat(2, 1fr); gap: 8px;">
                <div
                    style="display: flex; align-items: center; gap: 8px; padding: 10px; background: rgba(0, 186, 124, 0.05); border-radius: 8px;">
                    <div style="font-size: 18px;">🔊</div>
                    <div>
                        <div class="muted" style="font-size: 8px; font-weight: bold;">
                            <%= t("vc_joins") %>
                        </div>
                        <div id="stat-joins" style="font-size: 18px; font-weight: 900; color: #00BA7C;">0</div>
                    </div>
                </div>
                <div
                    style="display: flex; align-items: center; gap: 8px; padding: 10px; background: rgba(136, 153, 166, 0.05); border-radius: 8px;">
                    <div style="font-size: 18px;">🚪</div>
                    <div>
                        <div class="muted" style="font-size: 8px; font-weight: bold;">
                            <%= t("leaves") %>
                        </div>
                        <div id="stat-leaves" style="font-size: 18px; font-weight: 900; color: var(--text-secondary);">0
                        </div>
                    </div>
                </div>
                <div
                    style="display: flex; align-items: center; gap: 8px; padding: 10px; background: rgba(244, 33, 46, 0.05); border-radius: 8px;">
                    <div style="font-size: 18px;">⏳</div>
                    <div>
                        <div class="muted" style="font-size: 8px; font-weight: bold;">
                            <%= t("timeouts") %>
                        </div>
                        <div id="stat-timeouts" style="font-size: 18px; font-weight: 900; color: #F4212E;">0</div>
                    </div>
                </div>
                <div
                    style="display: flex; align-items: center; gap: 8px; padding: 10px; background: rgba(255, 173, 31, 0.05); border-radius: 8px;">
                    <div style="font-size: 18px;">🚫</div>
                    <div>
                        <div class="muted" style="font-size: 8px; font-weight: bold;">
                            <%= t("ng_detect") %>
                        </div>
                        <div id="stat-ng" style="font-size: 18px; font-weight: 900; color: #FFAD1F;">0</div>
                    </div>
                </div>
            </div>
        </div>

        <!-- Chart 2: Heatmap -->
        <div class="card" style="padding:10px; margin-bottom:0; min-height:200px;">
            <h4
                style="margin:0 0 12px 0; font-size:12px; font-weight:bold; color:var(--text-primary); border-bottom: 2px solid var(--accent-color); padding-bottom: 4px;">
                <span>🔥 <%= t("heatmap")%></span>
            </h4>
            <div style="height:150px;"><canvas id="heatmapChart"></canvas></div>
        </div>
    </div>

    <div id="card-raid" class="card" style="padding:12px; max-width: 1000px;">
        <h4
            style="margin:0 0 10px 0; font-size:13px; display:flex; align-items:center; justify-content:space-between; gap:6px;">
            <span>🛡️ Anti-Raid & Security</span>
        </h4>
        <table class="data-table" style="font-size:12px;">
            <thead>
                <tr>
                    <th style="text-align:left">
                        <%= t("header_user") %>
                    </th>
                    <th style="text-align:right">
                        <%= t("header_count") %>
                    </th>
                    <th style="text-align:right">Action</th>
                </tr>
            </thead>
            <tbody id="topNg"></tbody>
        </table>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
    <script>initDashboard();</script>