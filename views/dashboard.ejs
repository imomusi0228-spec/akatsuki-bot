<div style="max-width: 1000px; margin: 0 auto 20px auto;">
    <!-- Dashboard Top Bar: Month selector and Plan info -->
    <div class="card"
        style="padding: 12px 20px; margin-bottom: 20px; display: flex; align-items: center; justify-content: space-between; flex-wrap: wrap; gap: 15px; background: rgba(var(--accent-rgb), 0.03); border: 1px solid rgba(var(--accent-rgb), 0.1);">
        <div style="display: flex; align-items: center; gap: 10px;">
            <label for="month" class="muted"
                style="font-size: 11px; font-weight: bold; text-transform: uppercase; letter-spacing: 0.05em;">📅
                表示月指定</label>
            <input id="month" type="month"
                style="padding: 6px 12px; font-size: 13px; border-radius: 6px; border: 1px solid var(--border-color); background: rgba(0,0,0,0.3); color: white; outline: none;" />
        </div>

        <div style="display: flex; align-items: center; gap: 15px;">
            <div style="text-align: right;">
                <div class="muted" style="font-size: 10px; text-transform: uppercase;">
                    <%= t("plan_label") %>
                </div>
                <div id="plan-info"
                    style="font-size: 14px; font-weight: 800; color: var(--accent-color); text-shadow: 0 0 10px rgba(var(--accent-rgb), 0.3);">
                    ...</div>
            </div>
            <!-- Reload button is removed as per user request (Duplicate of global reload) -->
        </div>
    </div>

    <div
        style="display:grid; grid-template-columns: repeat(auto-fit, minmax(320px, 1fr)); gap:8px; margin-bottom:15px; max-width: 1000px; margin-left: auto; margin-right: auto; align-items: stretch;">
        <!-- Chart 1: Growth -->
        <div class="card" style="padding:15px; margin-bottom:0; min-height:260px; display:flex; flex-direction:column;">
            <h4
                style="margin:0 0 15px 0; font-size:14px; font-weight:800; color:var(--text-primary); border-bottom: 2px solid var(--accent-color); padding-bottom: 6px; text-transform:uppercase; letter-spacing:0.05em;">
                <span>📈 <%= t("growth_trend")%></span>
            </h4>
            <div style="flex:1;"><canvas id="growthChart"></canvas></div>
        </div>

        <!-- Stats Grid: Ultimate Stylish (v2.5.7) -->
        <div id="stats-grid" class="card"
            style="padding: 10px; margin-bottom: 0; min-height:260px; display:flex; flex-direction:column; justify-content:center; background: rgba(var(--accent-rgb), 0.02);">
            <div style="display: grid; grid-template-columns: repeat(2, 1fr); gap: 10px; height: 100%;">
                <!-- Joins -->
                <div
                    style="position: relative; overflow: hidden; display: flex; flex-direction: column; justify-content: center; align-items: center; padding: 20px; background: rgba(0, 186, 124, 0.03); border-radius: 12px; border: 1px solid rgba(0, 186, 124, 0.1);">
                    <div
                        style="position: absolute; font-size: 100px; opacity: 0.06; z-index: 0; bottom: -15px; right: -15px; transform: rotate(-15deg); pointer-events: none;">
                        🔊</div>
                    <div class="muted"
                        style="position: relative; z-index: 1; font-size: 14px; font-weight: 800; text-transform: uppercase; color: #00BA7C;">
                        <%= t("vc_joins") %>
                    </div>
                    <div id="stat-joins"
                        style="position: relative; z-index: 1; font-size: 52px; font-weight: 900; color: #00BA7C; line-height: 1;">
                        0</div>
                </div>
                <!-- Leaves -->
                <div
                    style="position: relative; overflow: hidden; display: flex; flex-direction: column; justify-content: center; align-items: center; padding: 20px; background: rgba(139, 155, 180, 0.03); border-radius: 12px; border: 1px solid rgba(139, 155, 180, 0.1);">
                    <div
                        style="position: absolute; font-size: 100px; opacity: 0.06; z-index: 0; bottom: -15px; right: -15px; transform: rotate(-15deg); pointer-events: none;">
                        🚪</div>
                    <div class="muted"
                        style="position: relative; z-index: 1; font-size: 14px; font-weight: 800; text-transform: uppercase; color: var(--text-secondary);">
                        <%= t("leaves") %>
                    </div>
                    <div id="stat-leaves"
                        style="position: relative; z-index: 1; font-size: 52px; font-weight: 900; color: var(--text-secondary); line-height: 1;">
                        0</div>
                </div>
                <!-- Timeouts -->
                <div
                    style="position: relative; overflow: hidden; display: flex; flex-direction: column; justify-content: center; align-items: center; padding: 20px; background: rgba(244, 33, 46, 0.03); border-radius: 12px; border: 1px solid rgba(244, 33, 46, 0.1);">
                    <div
                        style="position: absolute; font-size: 100px; opacity: 0.06; z-index: 0; bottom: -15px; right: -15px; transform: rotate(-15deg); pointer-events: none;">
                        ⏳</div>
                    <div class="muted"
                        style="position: relative; z-index: 1; font-size: 14px; font-weight: 800; text-transform: uppercase; color: #F4212E;">
                        <%= t("timeouts") %>
                    </div>
                    <div id="stat-timeouts"
                        style="position: relative; z-index: 1; font-size: 52px; font-weight: 900; color: #F4212E; line-height: 1;">
                        0</div>
                </div>
                <!-- NG Detect -->
                <div
                    style="position: relative; overflow: hidden; display: flex; flex-direction: column; justify-content: center; align-items: center; padding: 20px; background: rgba(255, 173, 31, 0.03); border-radius: 12px; border: 1px solid rgba(255, 173, 31, 0.1);">
                    <div
                        style="position: absolute; font-size: 100px; opacity: 0.06; z-index: 0; bottom: -15px; right: -15px; transform: rotate(-15deg); pointer-events: none;">
                        🚫</div>
                    <div class="muted"
                        style="position: relative; z-index: 1; font-size: 14px; font-weight: 800; text-transform: uppercase; color: #FFAD1F;">
                        <%= t("ng_detect") %>
                    </div>
                    <div id="stat-ng"
                        style="position: relative; z-index: 1; font-size: 52px; font-weight: 900; color: #FFAD1F; line-height: 1;">
                        0</div>
                </div>
            </div>
        </div>

        <!-- Chart 2: Heatmap -->
        <div class="card" style="padding:15px; margin-bottom:0; min-height:260px; display:flex; flex-direction:column;">
            <h4
                style="margin:0 0 15px 0; font-size:14px; font-weight:800; color:var(--text-primary); border-bottom: 2px solid var(--accent-color); padding-bottom: 6px; text-transform:uppercase; letter-spacing:0.05em;">
                <span>🔥 <%= t("heatmap")%></span>
            </h4>
            <div style="flex:1;"><canvas id="heatmapChart"></canvas></div>
        </div>
    </div>

    <div id="card-raid" class="card" style="padding:12px; max-width: 1000px;">
        <h4
            style="margin:0 0 10px 0; font-size:13px; display:flex; align-items:center; justify-content:space-between; gap:6px;">
            <span>🛡️ Anti-Raid & Security</span>
        </h4>
        <table class="data-table" style="font-size:12px;">
            <thead>
                <tr>
                    <th style="text-align:left">
                        <%= t("header_user") %>
                    </th>
                    <th style="text-align:right">
                        <%= t("header_count") %>
                    </th>
                    <th style="text-align:right">Action</th>
                </tr>
            </thead>
            <tbody id="topNg"></tbody>
        </table>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
    <script>
        document.addEventListener('DOMContentLoaded', () => {
            if (typeof initDashboard === 'function') initDashboard();
        });
    </script>