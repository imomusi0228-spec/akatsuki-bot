                        <input type="checkbox" id="mlRoleAdd"> <span style="font-size:13px;">✅ <%= t("log_role_add") %>
                        </span>
                    </label>
                    <label
                        style="display:flex; align-items:center; gap:8px; cursor:pointer; padding:8px; background:rgba(255,255,255,0.03); border-radius:6px;">
                        <input type="checkbox" id="mlRoleRemove"> <span style="font-size:13px;">❌ <%=
                                t("log_role_remove") %></span>
