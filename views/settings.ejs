<style>
    .accordion-item {
        border: 1px solid var(--border-color);
        border-radius: 8px;
        margin-bottom: 12px;
        background: rgba(255, 255, 255, 0.02);
    }

    .accordion-header {
        padding: 14px 20px;
        background: rgba(255, 255, 255, 0.03);
        cursor: pointer;
        display: flex;
        justify-content: space-between;
        align-items: center;
        font-weight: 600;
        transition: background 0.2s;
    }

    .accordion-header:hover {
        background: rgba(255, 255, 255, 0.07);
    }

    .accordion-content {
        padding: 20px;
        display: none;
        border-top: 1px solid var(--border-color);
        background: var(--card-bg);
    }

    .accordion-item.active .accordion-content {
        display: block;
    }

    .accordion-item.active .accordion-header {
        background: rgba(var(--accent-rgb), 0.15);
        color: var(--text-primary);
    }

    .ng-item {
        display: inline-flex;
        align-items: center;
        background: rgba(244, 33, 46, 0.1);
        color: #f4212e;
        border: 1px solid rgba(244, 33, 46, 0.2);
        padding: 4px 12px;
        border-radius: 20px;
        margin: 4px;
        font-size: 13px;
    }

    .ng-item button {
        background: none;
        border: none;
        color: #f4212e;
        margin-left: 8px;
        cursor: pointer;
        font-weight: bold;
        padding: 0 4px;
    }

    .help-icon {
        color: var(--text-secondary);
        cursor: help;
        font-size: 14px;
        margin-left: 6px;
    }
</style>

<div class="card" style="max-width: 1000px;">
    <div style="display:flex; justify-content:space-between; align-items:center; margin-bottom:20px;">
        <h3 style="margin:0;">
            <%= t("settings") %>
        </h3>
        <span id="saveStatus" style="font-size:14px; font-weight:bold;"></span>
    </div>


    <!-- ACCORDION START -->
    <div id="settings-accordion">

        <!-- 2. NG Words -->
        <div class="accordion-item active" id="sec-ng">
            <div class="accordion-header" onclick="toggleAccordion('sec-ng')">
                <span>🚫 <%= t("feature_ng_limit") %><span class="help-tip"
                            data-tip="<%= t('help_ng_limit') %>">?</span> <span id="ngCount" class="muted"
                            style="margin-left:10px; font-weight: normal;">0 <%= t("words") %></span></span>
                <span>▼</span>
            </div>
            <div class="accordion-content">
                <div style="display:flex; gap:10px; margin-bottom:15px;">
                    <input id="newWord" type="text" placeholder="Add word..." style="flex:1;">
                    <button onclick="addNg()" class="btn btn-primary">+</button>
                </div>
                <div id="ngList" style="background:rgba(0,0,0,0.2); border-radius:8px; padding:10px; min-height:60px;">
                </div>
                <p class="muted" style="margin-top:10px; font-size:11px; margin-bottom: 20px;">※スラッシュで囲むと正規表現として扱われます
                    (例: /badword/i)</p>

                <!-- Moved: Phase Escalation Settings -->
                <div style="border-top:1px solid var(--border-color); padding-top:20px; margin-top:18px;">
                    <div style="display:flex; align-items:center; justify-content:space-between; margin-bottom:15px;">
                        <label class="muted" style="margin:0;">⚠️ 段階制裁設定（NGワード自動エスカレーション）</label>
                        <label style="display:flex; align-items:center; cursor:pointer; font-size:12px;">
                            <input type="checkbox" id="ngWarningEnabled" checked
                                style="width:16px; height:16px; margin-right:8px;">
                            <span>
                                <%= t("ng_warning_enabled") %>
                            </span>
                        </label>
                    </div>
                    <div style="display:grid; grid-template-columns: 1fr 1fr 1fr; gap:15px;">
                        <div>
                            <label class="muted" style="font-size:12px;">フェーズ2：違反N回以上</label><br />
                            <input id="phase2Threshold" type="number" min="1" value="3"
                                style="width:100%; margin-top:5px;">
                            <select id="phase2Action" style="width:100%; margin-top:5px;">
                                <option value="timeout">タイムアウト</option>
                                <option value="kick">キック</option>
                                <option value="ban">BAN</option>
                            </select>
                        </div>
                        <div>
                            <label class="muted" style="font-size:12px;">フェーズ3：違反N回以上</label><br />
                            <input id="phase3Threshold" type="number" min="1" value="6"
                                style="width:100%; margin-top:5px;">
                            <select id="phase3Action" style="width:100%; margin-top:5px;">
                                <option value="timeout">タイムアウト</option>
                                <option value="kick">キック</option>
                                <option value="ban">BAN</option>
                            </select>
                        </div>
                        <div>
                            <label class="muted" style="font-size:12px;">フェーズ4：違反N回以上</label><br />
                            <input id="phase4Threshold" type="number" min="1" value="10"
                                style="width:100%; margin-top:5px;">
                            <select id="phase4Action" style="width:100%; margin-top:5px;">
                                <option value="timeout">タイムアウト</option>
                                <option value="kick">キック</option>
                                <option value="ban">BAN</option>
                            </select>
                        </div>
                    </div>
                    <p class="muted" style="font-size:11px; margin-top:8px;">※ 過去1時間のNG違反回数が各しきい値に達すると選択したアクションが実行されます。
                    </p>
                </div>
                <!-- アップデート通知チャンネル -->
                <div style="border-top:1px solid var(--border-color); padding-top:20px; margin-top:20px;">
                    <label class="muted" style="display:block; margin-bottom:8px; font-size:13px; font-weight:600;">
                        🌟 アップデートお知らせチャンネル
                    </label>
                    <select id="updateAnnounceCh" style="width:100%; max-width:400px; margin-top:5px;"></select>
                    <p class="muted" style="font-size:11px; margin-top:5px;">
                        ※ <code
                            style="background:rgba(255,255,255,0.1); padding:1px 5px; border-radius:3px;">npm run notify</code>
                        実行時に、新バージョンのみをこのチャンネルへ自動投稿します。空欄の場合は通知しません。
                    </p>
                </div>
            </div>
        </div>

        <!-- B-9. 手動警告管理 -->
        <div class="accordion-item" id="sec-warn">
            <div class="accordion-header" onclick="toggleAccordion('sec-warn')">
                <span>⚠️ 手動警告管理（B-9）</span>
                <span>▼</span>
            </div>
            <div class="accordion-content">
                <p class="muted" style="font-size:12px; margin-bottom:15px;">
                    メンバー監査ページから手動で警告を発行・確認できます。ここでは警告が一定回数に達した場合の自動アクションを設定します。
                </p>
                <label style="display:flex; align-items:center; cursor:pointer; margin-bottom:20px;">
                    <input type="checkbox" id="autoActionOnWarns" style="width:18px; height:18px; margin-right:10px;">
                    <span style="font-weight:bold;">警告N回達成時に自動アクションを実行する</span>
                </label>
                <div style="display:grid; grid-template-columns: 1fr 1fr; gap:20px;">
                    <div>
                        <label class="muted" style="font-size:12px;">自動アクション発動しきい値（回）</label><br />
                        <input id="warnActionThreshold" type="number" min="1" value="3"
                            style="width:100%; margin-top:5px;">
                    </div>
                    <div>
                        <label class="muted" style="font-size:12px;">実行するアクション</label><br />
                        <select id="warnAction" style="width:100%; margin-top:5px;">
                            <option value="timeout">タイムアウト</option>
                            <option value="kick">キック</option>
                            <option value="ban">BAN</option>
                        </select>
                    </div>
                </div>
                <p class="muted" style="font-size:11px; margin-top:10px;">
                    ※ タイムアウト時間は「ログ設定」→「タイムアウト時間」の設定値が使用されます。
                </p>
            </div>
        </div>

        <!-- A-1 / A-2: XPランキング・レベルアップ設定 -->
        <div class="accordion-item" id="sec-level">
            <div class="accordion-header" onclick="toggleAccordion('sec-level')">
                <span>📊 XPランキング・レベルアップ通知（A-1 / A-2）</span>
                <span>▼</span>
            </div>
            <div class="accordion-content">
                <!-- A-1 -->
                <div style="margin-bottom:20px;">
                    <label style="display:flex; align-items:center; cursor:pointer; margin-bottom:8px;">
                        <input type="checkbox" id="leaderboardEnabled"
                            style="width:18px; height:18px; margin-right:10px;">
                        <span style="font-weight:bold;">🏆 XPランキング機能を有効化（/level leaderboard）</span>
                    </label>
                    <p class="muted" style="font-size:11px;">OFFにするとランキングコマンドが使用不可になります。XP自体は引き続き蓄積されます。</p>
                </div>
                <!-- A-2 -->
                <div style="border-top:1px solid var(--border-color); padding-top:20px;">
                    <label style="display:flex; align-items:center; cursor:pointer; margin-bottom:15px;">
                        <input type="checkbox" id="levelupEnabled" style="width:18px; height:18px; margin-right:10px;">
                        <span style="font-weight:bold;">🎉 レベルアップ通知を有効化</span>
                    </label>
                    <label class="muted" style="font-size:12px;">通知送信先チャンネル（空欄 = 発言チャンネルに通知）</label><br />
                    <select id="levelupCh" style="width:100%; max-width:400px; margin-top:5px;"></select>
                    <p class="muted" style="font-size:11px; margin-top:5px;">※ チャンネルを選択するとそのチャンネルに固定送信されます。</p>
                </div>
            </div>
        </div>

        <!-- A-3: 入退室メッセージカスタマイズ -->
        <div class="accordion-item" id="sec-welcome">
            <div class="accordion-header" onclick="toggleAccordion('sec-welcome')">
                <span>📝 入退室メッセージカスタマイズ（A-3）</span>
                <span>▼</span>
            </div>
            <div class="accordion-content">
                <p class="muted" style="font-size:12px; margin-bottom:15px;">
                    メンバーがサーバーに参加・退出した際に送信するメッセージを設定します。<br>
                    <code
                        style="background:rgba(255,255,255,0.1); padding:2px 6px; border-radius:4px;">{user}</code>…メンション
                    <code
                        style="background:rgba(255,255,255,0.1); padding:2px 6px; border-radius:4px;">{username}</code>…名前
                    <code
                        style="background:rgba(255,255,255,0.1); padding:2px 6px; border-radius:4px;">{server}</code>…サーバー名
                </p>
                <!-- Welcome -->
                <div style="margin-bottom:20px;">
                    <label style="display:flex; align-items:center; cursor:pointer; margin-bottom:12px;">
                        <input type="checkbox" id="welcomeEnabled" style="width:18px; height:18px; margin-right:10px;">
                        <span style="font-weight:bold;">👋 参加メッセージを有効化</span>
                    </label>
                    <div style="display:grid; grid-template-columns: 1fr 1fr; gap:15px;">
                        <div>
                            <label class="muted" style="font-size:12px;">送信先チャンネル</label><br />
                            <select id="welcomeCh" style="width:100%; margin-top:5px;"></select>
                        </div>
                        <div>
                            <label class="muted" style="font-size:12px;">メッセージ内容</label><br />
                            <textarea id="welcomeMsg" rows="2" placeholder="{user} さん、{server} へようこそ！"
                                style="width:100%; margin-top:5px; background:var(--card-bg); color:var(--text-primary); border:1px solid var(--border-color); border-radius:6px; padding:8px; font-size:13px;"></textarea>
                        </div>
                    </div>
                </div>
                <!-- Farewell -->
                <div style="border-top:1px solid var(--border-color); padding-top:20px;">
                    <label style="display:flex; align-items:center; cursor:pointer; margin-bottom:12px;">
                        <input type="checkbox" id="farewellEnabled" style="width:18px; height:18px; margin-right:10px;">
                        <span style="font-weight:bold;">🚪 退出メッセージを有効化</span>
                    </label>
                    <div style="display:grid; grid-template-columns: 1fr 1fr; gap:15px;">
                        <div>
                            <label class="muted" style="font-size:12px;">送信先チャンネル</label><br />
                            <select id="farewellCh" style="width:100%; margin-top:5px;"></select>
                        </div>
                        <div>
                            <label class="muted" style="font-size:12px;">メッセージ内容</label><br />
                            <textarea id="farewellMsg" rows="2" placeholder="{username} さんが退出しました。"
                                style="width:100%; margin-top:5px; background:var(--card-bg); color:var(--text-primary); border:1px solid var(--border-color); border-radius:6px; padding:8px; font-size:13px;"></textarea>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <!-- B-8: モデレーションログ強化 -->
        <div class="accordion-item" id="sec-modlog">
            <div class="accordion-header" onclick="toggleAccordion('sec-modlog')">
                <span>📋 モデレーションログ強化（B-8）</span>
                <span>▼</span>
            </div>
            <div class="accordion-content">
                <p class="muted" style="font-size:12px; margin-bottom:15px;">
                    記録するログの種別と送信先チャンネルを設定します。
                </p>
                <div style="margin-bottom:15px;">
                    <label class="muted" style="font-size:12px;">ログ送信先チャンネル</label><br />
                    <select id="modLogCh" style="width:100%; max-width:400px; margin-top:5px;"></select>
                </div>
                <div style="display:grid; grid-template-columns: 1fr 1fr; gap:10px;">
                    <label
                        style="display:flex; align-items:center; gap:8px; cursor:pointer; padding:8px; background:rgba(255,255,255,0.03); border-radius:6px;">
                        <input type="checkbox" id="mlBan" checked> <span style="font-size:13px;">🔨 BAN</span>
                    </label>
                    <label
                        style="display:flex; align-items:center; gap:8px; cursor:pointer; padding:8px; background:rgba(255,255,255,0.03); border-radius:6px;">
                        <input type="checkbox" id="mlKick" checked> <span style="font-size:13px;">👢 キック</span>
                    </label>
                    <label
                        style="display:flex; align-items:center; gap:8px; cursor:pointer; padding:8px; background:rgba(255,255,255,0.03); border-radius:6px;">
                        <input type="checkbox" id="mlRoleAdd"> <span style="font-size:13px;">✅ ロール付与</span>
                    </label>
                    <label
                        style="display:flex; align-items:center; gap:8px; cursor:pointer; padding:8px; background:rgba(255,255,255,0.03); border-radius:6px;">
                        <input type="checkbox" id="mlRoleRemove"> <span style="font-size:13px;">❌ ロール剥奪</span>
                    </label>
                    <label
                        style="display:flex; align-items:center; gap:8px; cursor:pointer; padding:8px; background:rgba(255,255,255,0.03); border-radius:6px;">
                        <input type="checkbox" id="mlChCreate"> <span style="font-size:13px;">📂 チャンネル作成</span>
                    </label>
                    <label
                        style="display:flex; align-items:center; gap:8px; cursor:pointer; padding:8px; background:rgba(255,255,255,0.03); border-radius:6px;">
                        <input type="checkbox" id="mlChDelete"> <span style="font-size:13px;">🗑️ チャンネル削除</span>
                    </label>
                    <label
                        style="display:flex; align-items:center; gap:8px; cursor:pointer; padding:8px; background:rgba(255,255,255,0.03); border-radius:6px;">
                        <input type="checkbox" id="mlMsgEdit"> <span style="font-size:13px;">✏️ メッセージ編集</span>
                    </label>
                    <label
                        style="display:flex; align-items:center; gap:8px; cursor:pointer; padding:8px; background:rgba(255,255,255,0.03); border-radius:6px;">
                        <input type="checkbox" id="mlMsgDelete"> <span style="font-size:13px;">🗑️ メッセージ削除</span>
                    </label>
                </div>
            </div>
        </div>

        <!-- 4. Self Introduction Gate -->
        <div class="accordion-item" id="sec-intro">
            <div class="accordion-header" onclick="toggleAccordion('sec-intro')">
                <span>📝 <%= t("roadmap_introgate") %>
                        <span class="help-tip" data-tip="<%= t('help_introgate') %>">?</span>
                </span>
                <span>▼</span>
            </div>

            <div class="accordion-content">

                <!-- Enable Toggle -->
                <div style="margin-bottom:15px;">
                    <label style="display:flex; align-items:center; cursor:pointer;">
                        <input type="checkbox" id="introGateEnabled"
                            style="width:18px; height:18px; margin-right:10px;">
                        <span>自己紹介ゲートを有効化</span>
                    </label>
                </div>

                <!-- Main Grid -->
                <div style="display:grid; grid-template-columns: 1fr 1fr; gap:20px;">
                    <div>
                        <label class="muted">付与するロール</label><br />
                        <select id="introRole" style="width:100%; margin-top:5px;"></select>
                    </div>
                    <div>
                        <label class="muted">必要最小文字数</label><br />
                        <input id="introMinLen" type="number" min="1" value="10" style="width:100%; margin-top:5px;">
                    </div>
                </div>

                <!-- Intro Channel Select -->
                <div style="margin-top:15px;">
                    <label class="muted">📝 自己紹介チャンネル</label><br />
                    <select id="introChannel" style="width:100%; margin-top:5px;"></select>
                    <p class="muted" style="font-size:11px; margin-top:5px;">
                        ※ このサーバーのテキストチャンネルのみ表示されます。
                    </p>
                </div>

                <!-- Reminder -->
                <div style="margin-top:20px;">
                    <label class="muted">
                        📬 未投稿リマインダー (参加からN時間後にDM送信)
                    </label><br />
                    <input id="introReminderHours" type="number" min="0" max="720" value="24"
                        style="width:100%; max-width:200px; margin-top:5px;">
                    <p class="muted" style="font-size:11px; margin-top:5px;">
                        0に設定すると無効になります。
                    </p>
                </div>
            </div>
        </div>

        <script>
            document.addEventListener('DOMContentLoaded', async () => {

                if (typeof initSettings === 'function') {
                    initSettings();
                }

                const select = document.getElementById("introChannel");
                if (!select) return;

                select.innerHTML = '<option value="">読み込み中...</option>';

                try {
                    const res = await fetch("/api/guild/channels");
                    if (!res.ok) throw new Error("Failed");

                    const channels = await res.json();

                    select.innerHTML = '<option value="">選択してください</option>';

                    channels
                        .filter(ch => ch.type === 0)
                        .forEach(ch => {
                            const opt = document.createElement("option");
                            opt.value = ch.id;
                            opt.textContent = "# " + ch.name;
                            select.appendChild(opt);
                        });

                } catch (err) {
                    console.error("Channel loading error:", err);
                    select.innerHTML = '<option value="">読み込み失敗</option>';
                }

            });
        </script>

        <!-- 5. Channels -->
        <div class="accordion-item" id="sec-ch">
            <div class="accordion-header" onclick="toggleAccordion('sec-ch')">
                <span>📢 <%= t("log_settings") %></span>
                <span>▼</span>
            </div>
            <div class="accordion-content">
                <div style="display:grid; grid-template-columns: 1fr 1fr; gap:20px;">
                    <div>
                        <label class="muted">
                            <%= t("vc_log_ch") %>
                        </label><br />
                        <select id="logCh" style="width:100%; margin-top:5px;"></select>
                    </div>
                    <div>
                        <label class="muted">
                            <%= t("ng_log_ch") %>
                        </label><br />
                        <select id="ngLogCh" style="width:100%; margin-top:5px;"></select>
                    </div>
                </div>

                <!-- Auto Slowmode Settings (v2.8.2) -->
                <div style="border-top:1px solid var(--border-color); padding-top:20px; margin-top:20px;">
                    <label style="display:flex; align-items:center; cursor:pointer; margin-bottom:15px;">
                        <input type="checkbox" id="autoSlowmodeEnabled"
                            style="width:18px; height:18px; margin-right:10px;">
                        <span style="font-weight:bold;">🚨 異常検知時の自動低速モードを有効化</span>
                    </label>
                    <div style="margin-bottom:10px;">
                        <label class="muted" style="font-size:12px;">適用対象チャンネル（複数選択可 / Ctrl+クリック）</label><br />
                        <select id="autoSlowmodeChannels" multiple
                            style="width:100%; height:120px; margin-top:5px; padding:8px; background:rgba(0,0,0,0.3); border:1px solid var(--border-color); border-radius:6px; color:white;">
                        </select>
                        <p class="muted" style="font-size:11px; margin-top:5px;">
                            ※ 大量のNGワードや不自然なメッセージ密度を検知した際、指定したチャンネルを自動的に低速モード（10秒）に設定します。
                        </p>
                    </div>
                </div>
            </div>
        </div>

        <!-- 6. VC Related (Roles & Reports) -->
        <div class="accordion-item" id="sec-vc">
            <div class="accordion-header" onclick="toggleAccordion('sec-vc')">
                <span>🎤 VC高度設定 (Roles & Reports)</span>
                <span>▼</span>
            </div>
            <div class="accordion-content">
                <!-- Role Rules -->
                <div style="margin-bottom:24px;">
                    <label class="muted" style="display:block; margin-bottom:10px;">VC活動時間に応じたオーラ付与（名称と時間）<span
                            class="help-tip" data-tip="<%= t('help_vc_role') %>">?</span></label>
                    <div id="roleRulesList" style="display:flex; flex-direction:column; gap:8px; margin-bottom:10px;">
                    </div>
                    <button type="button" onclick="addRoleRule()" class="btn" style="font-size:12px; width:100%;">+
                        オーラを追加</button>

                </div>

                <!-- Reports -->
                <div style="border-top:1px solid var(--border-color); padding-top:20px;">
                    <label style="display:flex; align-items:center; cursor:pointer; margin-bottom:15px;">
                        <input type="checkbox" id="vcReportEnabled" style="width:18px; height:18px; margin-right:10px;">
                        <span>VCアクティビティ週報を有効化<span class="help-tip"
                                data-tip="<%= t('help_vc_report') %>">?</span></span>
                    </label>
                    <div style="display:grid; grid-template-columns: 1fr 1fr; gap:20px;">
                        <div>
                            <label class="muted">レポート送信先</label><br />
                            <select id="vcReportCh" style="width:100%; margin-top:5px;"></select>
                        </div>
                        <div>
                            <label class="muted">送信間隔</label><br />
                            <select id="vcReportInterval" style="width:100%; margin-top:5px;">
                                <option value="daily">毎日</option>
                                <option value="weekly" selected>毎週</option>
                                <option value="monthly">毎月</option>
                            </select>
                        </div>
                    </div>
                </div>

                <!-- Dynamic VC (Auto-VC) -->
                <div style="border-top:1px solid var(--border-color); padding-top:20px; margin-top:20px;">
                    <label class="muted">📂 Auto-VC 対象カテゴリ<span class="help-tip"
                            data-tip="指定したカテゴリ内の最上位チャンネルに入ると、自分専用のVCが自動生成されます。">?</span></label><br />
                    <select id="autoVcCategory" style="width:100%; max-width:400px; margin-top:5px;"></select>
                    <p class="muted" style="font-size:11px; margin-top:5px;">※ カテゴリ内の最上位VCに入室時に作成、退出時（0人時）に削除されます。</p>
                </div>
            </div>
        </div>


        <!-- 7. Button Roles (v2.8.0) -->
        <div class="accordion-item" id="sec-br">
            <div class="accordion-header" onclick="toggleAccordion('sec-br')">
                <span>🔘 ボタンロール管理</span>
                <span>▼</span>
            </div>
            <div class="accordion-content">
                <p class="muted" style="font-size:12px; margin-bottom:15px;">
                    ボタンを押すと役職が付与されるメッセージを作成・管理します。既存パネルの編集も可能です。</p>

                <!-- Creator Form -->
                <div
                    style="background: rgba(0,0,0,0.1); padding: 15px; border-radius: 8px; margin-bottom: 25px; border: 1px solid var(--border-color);">
                    <h4
                        style="margin-top:0; font-size:14px; color: var(--accent-color); border-bottom: 1px solid var(--border-color); padding-bottom: 8px; margin-bottom: 15px;">
                        🎨 パネル作成・編集</h4>
                    <input type="hidden" id="brId" value="">
                    <input type="hidden" id="brMessageId" value="">

                    <div style="display:grid; grid-template-columns: 1fr 1fr; gap:15px; margin-bottom:15px;">
                        <div>
                            <label class="muted">送信先チャンネル</label><br />
                            <select id="brChannel" style="width:100%; margin-top:5px;"></select>
                        </div>
                        <div>
                            <label class="muted">アクセントカラー</label><br />
                            <div style="display:flex; gap:10px; align-items:center; margin-top:5px;">
                                <input type="color" id="brColor" value="#5865F2"
                                    style="width:40px; height:35px; border:none; padding:0; background:none; cursor:pointer;"
                                    oninput="document.getElementById('brColorHex').value = this.value.toUpperCase()">
                                <input type="text" id="brColorHex" value="#5865F2"
                                    style="flex:1; font-family:monospace; text-transform:uppercase;" maxlength="7"
                                    oninput="document.getElementById('brColor').value = this.value">
                            </div>
                        </div>
                    </div>

                    <div style="margin-bottom:15px;">
                        <label class="muted">タイトル（埋め込み）</label><br />
                        <input id="brTitle" type="text" placeholder="役職パネル" style="width:100%; margin-top:5px;">
                    </div>

                    <div style="margin-bottom:15px;">
                        <label class="muted">メッセージ本文</label><br />
                        <textarea id="brContent" rows="3"
                            style="width:100%; margin-top:5px; background:var(--card-bg); color:var(--text-color); border:1px solid var(--border-color); border-radius:4px; padding:8px;"
                            placeholder="空欄の場合は自動的に説明文が生成されます"></textarea>
                    </div>

                    <div style="margin-bottom:15px;">
                        <label class="muted">ボタン設定（1行に最大5個）</label>
                        <div id="brButtonsList" style="display:flex; flex-direction:column; gap:8px; margin-top:8px;">
                            <!-- Button Rows loaded via JS -->
                        </div>
                        <button type="button" onclick="addBrButtonRow()" class="btn"
                            style="font-size:12px; width:100%; margin-top:10px; background:rgba(255,255,255,0.05); border:1px dashed var(--border-color);">+
                            ボタンを追加</button>
                    </div>

                    <div style="display:flex; gap:10px; margin-top:20px;">
                        <button type="button" onclick="saveButtonRole()" class="btn btn-primary"
                            style="flex:2; padding:10px;">🚀 Discordに送信・保存</button>
                        <button type="button" onclick="resetBrForm()" class="btn"
                            style="flex:1; padding:10px;">リセット</button>
                    </div>
                </div>

                <h4 style="font-size:14px; margin-bottom:12px; display:flex; align-items:center; gap:8px;">
                    <span style="width:8px; height:8px; background:var(--accent-color); border-radius:50%;"></span>
                    作成済みパネル一覧
                </h4>
                <div id="br-loading" class="muted" style="text-align:center; padding:15px; display:none;">ロード中...</div>
                <div id="br-list" style="display:flex; flex-direction:column; gap:12px;">
                    <!-- Button Role List Items -->
                </div>
            </div>
        </div>

    </div>
</div>


<!-- ACCORDION END -->



<div style="margin-top:30px; display:flex; gap:15px;">
    <button id="save" class="btn btn-primary" style="flex:1; padding:12px; font-size:16px;">
        <%= t("save_settings") %>
    </button>
</div>