<div style="max-width: 1000px; margin: 0 auto 20px auto;">
    <!-- Dashboard Top Bar: Month selector and Plan info -->
    <div class="card"
        style="padding: 12px 20px; margin-bottom: 20px; display: flex; align-items: center; justify-content: space-between; flex-wrap: wrap; gap: 15px; background: rgba(var(--accent-rgb), 0.03); border: 1px solid rgba(var(--accent-rgb), 0.1);">
        <div style="display: flex; align-items: center; gap: 10px;">
            <label for="month" class="muted"
                style="font-size: 11px; font-weight: bold; text-transform: uppercase; letter-spacing: 0.05em;">📅
                <%= t("display_month_select") %>
            </label>
            <input id="month" type="month"
                style="padding: 6px 12px; font-size: 13px; border-radius: 6px; border: 1px solid var(--border-color); background: rgba(0,0,0,0.3); color: white; outline: none;" />
        </div>

        <div style="display: flex; align-items: center; gap: 15px;">
            <div style="text-align: right;">
                <div class="muted" style="font-size: 10px; text-transform: uppercase;">
                    <%= t("plan_label") %>
                </div>
                <div id="plan-info"
                    style="font-size: 14px; font-weight: 800; color: var(--accent-color); text-shadow: 0 0 10px rgba(var(--accent-rgb), 0.3);">
                    ...</div>
            </div>
            <!-- Reload button is removed as per user request (Duplicate of global reload) -->
        </div>
    </div>

    <!-- ===== B-6: リアルタイム統計パネル ===== -->
    <div id="realtime-panel" style="margin-bottom: 15px;">
        <div style="display: flex; align-items: center; justify-content: space-between; margin-bottom: 10px;">
            <div style="display: flex; align-items: center; gap: 8px;">
                <span
                    style="font-size: 13px; font-weight: 800; text-transform: uppercase; letter-spacing: 0.08em; color: var(--text-primary);">⚡
                    <%= t("realtime_title") %>
                </span>
                <span id="rt-status-dot"
                    style="width: 8px; height: 8px; border-radius: 50%; background: #00BA7C; display: inline-block; box-shadow: 0 0 6px #00BA7C; animation: rtPulse 2s infinite;"></span>
            </div>
            <span id="rt-last-updated" style="font-size: 11px; color: var(--text-secondary);">
                <%= t("updating") %>
            </span>
        </div>
        <div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(140px, 1fr)); gap: 8px;">
            <!-- オンライン -->
            <div class="rt-card"
                style="background: rgba(0,186,124,0.06); border: 1px solid rgba(0,186,124,0.15); border-radius: 12px; padding: 14px; text-align: center;">
                <div style="font-size: 22px; margin-bottom: 4px;">🟢</div>
                <div id="rt-online" style="font-size: 28px; font-weight: 900; color: #00BA7C; line-height: 1;">—</div>
                <div style="font-size: 11px; color: var(--text-secondary); margin-top: 4px; font-weight: 600;">
                    <%= t("rt_online") %>
                </div>
            </div>
            <!-- 現在VC中 -->
            <div class="rt-card"
                style="background: rgba(29,161,242,0.06); border: 1px solid rgba(29,161,242,0.15); border-radius: 12px; padding: 14px; text-align: center;">
                <div style="font-size: 22px; margin-bottom: 4px;">🔊</div>
                <div id="rt-active-vc" style="font-size: 28px; font-weight: 900; color: #1DA1F2; line-height: 1;">—
                </div>
                <div style="font-size: 11px; color: var(--text-secondary); margin-top: 4px; font-weight: 600;">
                    <%= t("rt_active_vc") %>
                </div>
            </div>
            <!-- 今日のVC参加 -->
            <div class="rt-card"
                style="background: rgba(29,161,242,0.04); border: 1px solid rgba(29,161,242,0.1); border-radius: 12px; padding: 14px; text-align: center;">
                <div style="font-size: 22px; margin-bottom: 4px;">📊</div>
                <div id="rt-today-vc" style="font-size: 28px; font-weight: 900; color: #1DA1F2; line-height: 1;">—</div>
                <div style="font-size: 11px; color: var(--text-secondary); margin-top: 4px; font-weight: 600;">
                    <%= t("rt_today_vc") %>
                </div>
            </div>
            <!-- 今日の新規参加 -->
            <div class="rt-card"
                style="background: rgba(255,173,31,0.06); border: 1px solid rgba(255,173,31,0.15); border-radius: 12px; padding: 14px; text-align: center;">
                <div style="font-size: 22px; margin-bottom: 4px;">👋</div>
                <div id="rt-today-joins" style="font-size: 28px; font-weight: 900; color: #FFAD1F; line-height: 1;">—
                </div>
                <div style="font-size: 11px; color: var(--text-secondary); margin-top: 4px; font-weight: 600;">
                    <%= t("rt_today_joins") %>
                </div>
            </div>
            <!-- 今週NG -->
            <div class="rt-card"
                style="background: rgba(244,33,46,0.06); border: 1px solid rgba(244,33,46,0.15); border-radius: 12px; padding: 14px; text-align: center;">
                <div style="font-size: 22px; margin-bottom: 4px;">🚫</div>
                <div id="rt-week-ng" style="font-size: 28px; font-weight: 900; color: #F4212E; line-height: 1;">—</div>
                <div style="font-size: 11px; color: var(--text-secondary); margin-top: 4px; font-weight: 600;">
                    <%= t("rt_week_ng") %>
                </div>
            </div>
            <!-- 今週タイムアウト -->
            <div class="rt-card"
                style="background: rgba(244,33,46,0.04); border: 1px solid rgba(244,33,46,0.1); border-radius: 12px; padding: 14px; text-align: center;">
                <div style="font-size: 22px; margin-bottom: 4px;">⏱️</div>
                <div id="rt-week-timeout" style="font-size: 28px; font-weight: 900; color: #F4212E; line-height: 1;">—
                </div>
                <div style="font-size: 11px; color: var(--text-secondary); margin-top: 4px; font-weight: 600;">
                    <%= t("rt_week_timeout") %>
                </div>
            </div>
        </div>
    </div>
    <style>
        @keyframes rtPulse {

            0%,
            100% {
                opacity: 1;
                transform: scale(1);
            }

            50% {
                opacity: 0.4;
                transform: scale(0.8);
            }
        }

        .rt-card {
            transition: transform 0.2s, box-shadow 0.2s;
        }

        .rt-card:hover {
            transform: translateY(-2px);
            box-shadow: 0 4px 16px rgba(0, 0, 0, 0.2);
        }

        .rt-num-flash {
            animation: rtFlash 0.4s ease;
        }

        @keyframes rtFlash {
            0% {
                opacity: 0.3;
                transform: scale(0.9);
            }

            100% {
                opacity: 1;
                transform: scale(1);
            }
        }
    </style>
    <!-- ===== /B-6 ===== -->

    <div
        style="display:grid; grid-template-columns: repeat(auto-fit, minmax(320px, 1fr)); gap:8px; margin-bottom:15px; max-width: 1000px; margin-left: auto; margin-right: auto; align-items: stretch;">
        <!-- Chart 1: Growth -->
        <div class="card" style="padding:15px; margin-bottom:0; min-height:260px; display:flex; flex-direction:column;">
            <h4
                style="margin:0 0 15px 0; font-size:14px; font-weight:800; color:var(--text-primary); border-bottom: 2px solid var(--accent-color); padding-bottom: 6px; text-transform:uppercase; letter-spacing:0.05em;">
                <span>📈 <%= t("growth_trend")%></span>
            </h4>
            <div style="flex:1;"><canvas id="growthChart"></canvas></div>
        </div>

        <!-- Stats Grid: ULTIMATE Stylish (v2.7.0) -->
        <div id="stats-grid" class="card"
            style="padding: 10px; margin-bottom: 0; min-height:260px; display:flex; flex-direction:column; justify-content:center; background: rgba(var(--accent-rgb), 0.02);">
            <div style="display: grid; grid-template-columns: repeat(2, 1fr); gap: 10px; height: 100%;">
                <!-- Joins -->
                <div
                    style="position: relative; overflow: hidden; display: flex; flex-direction: column; justify-content: center; align-items: center; padding: 20px; background: rgba(0, 186, 124, 0.03); border-radius: 12px; border: 1px solid rgba(0, 186, 124, 0.1);">
                    <div
                        style="position: absolute; font-size: 100px; opacity: 0.06; z-index: 0; bottom: -15px; right: -15px; transform: rotate(-15deg); pointer-events: none;">
                        🔊</div>
                    <div class="muted"
                        style="position: relative; z-index: 1; font-size: 14px; font-weight: 800; text-transform: uppercase; color: #00BA7C;">
                        <%= t("vc_joins") %>
                    </div>
                    <div id="stat-joins"
                        style="position: relative; z-index: 1; font-size: 52px; font-weight: 900; color: #00BA7C; line-height: 1;">
                        0</div>
                </div>
                <!-- Leaves -->
                <div
                    style="position: relative; overflow: hidden; display: flex; flex-direction: column; justify-content: center; align-items: center; padding: 20px; background: rgba(139, 155, 180, 0.03); border-radius: 12px; border: 1px solid rgba(139, 155, 180, 0.1);">
                    <div
                        style="position: absolute; font-size: 100px; opacity: 0.06; z-index: 0; bottom: -15px; right: -15px; transform: rotate(-15deg); pointer-events: none;">
                        🚪</div>
                    <div class="muted"
                        style="position: relative; z-index: 1; font-size: 14px; font-weight: 800; text-transform: uppercase; color: var(--text-secondary);">
                        <%= t("leaves") %>
                    </div>
                    <div id="stat-leaves"
                        style="position: relative; z-index: 1; font-size: 52px; font-weight: 900; color: var(--text-secondary); line-height: 1;">
                        0</div>
                </div>
                <!-- Timeouts -->
                <div
                    style="position: relative; overflow: hidden; display: flex; flex-direction: column; justify-content: center; align-items: center; padding: 20px; background: rgba(244, 33, 46, 0.03); border-radius: 12px; border: 1px solid rgba(244, 33, 46, 0.1);">
                    <div
                        style="position: absolute; font-size: 100px; opacity: 0.06; z-index: 0; bottom: -15px; right: -15px; transform: rotate(-15deg); pointer-events: none;">
                        ⏳</div>
                    <div class="muted"
                        style="position: relative; z-index: 1; font-size: 14px; font-weight: 800; text-transform: uppercase; color: #F4212E;">
                        <%= t("timeouts") %>
                    </div>
                    <div id="stat-timeouts"
                        style="position: relative; z-index: 1; font-size: 52px; font-weight: 900; color: #F4212E; line-height: 1;">
                        0</div>
                </div>
                <!-- NG Detect -->
                <div
                    style="position: relative; overflow: hidden; display: flex; flex-direction: column; justify-content: center; align-items: center; padding: 20px; background: rgba(255, 173, 31, 0.03); border-radius: 12px; border: 1px solid rgba(255, 173, 31, 0.1);">
                    <div
                        style="position: absolute; font-size: 100px; opacity: 0.06; z-index: 0; bottom: -15px; right: -15px; transform: rotate(-15deg); pointer-events: none;">
                        🚫</div>
                    <div class="muted"
                        style="position: relative; z-index: 1; font-size: 14px; font-weight: 800; text-transform: uppercase; color: #FFAD1F;">
                        <%= t("ng_detect") %>
                    </div>
                    <div id="stat-ng"
                        style="position: relative; z-index: 1; font-size: 52px; font-weight: 900; color: #FFAD1F; line-height: 1;">
                        0</div>
                </div>
            </div>
        </div>

        <!-- Chart 2: Heatmap -->
        <div class="card" style="padding:15px; margin-bottom:0; min-height:260px; display:flex; flex-direction:column;">
            <h4
                style="margin:0 0 15px 0; font-size:14px; font-weight:800; color:var(--text-primary); border-bottom: 2px solid var(--accent-color); padding-bottom: 6px; text-transform:uppercase; letter-spacing:0.05em;">
                <span>🔥 <%= t("heatmap")%></span>
            </h4>
            <div style="flex:1;"><canvas id="heatmapChart"></canvas></div>
        </div>
    </div>

    <div
        style="display:grid; grid-template-columns: repeat(auto-fit, minmax(480px, 1fr)); gap:15px; margin-bottom:15px;">
        <!-- Activity Leaderboard -->
        <div class="card" style="padding:15px; margin-bottom:0;">
            <h4
                style="margin:0 0 15px 0; font-size:14px; font-weight:800; color:var(--text-primary); border-bottom: 2px solid #FFD700; padding-bottom: 6px; text-transform:uppercase; letter-spacing:0.05em;">
                <span>🏆 <%= t("leaderboard_title", {count: 10}) %></span>
            </h4>
            <div style="overflow-x: auto;">
                <table class="data-table" style="font-size:12px; width:100%;">
                    <thead>
                        <tr>
                            <th style="text-align:left; width:40px;">#</th>
                            <th style="text-align:left;">
                                <%= t("header_user") %>
                            </th>
                            <th style="text-align:center;">LV</th>
                            <th style="text-align:right;">
                                <%= t("header_xp") %>
                            </th>
                            <th style="text-align:right;">
                                <%= t("header_messages") %>
                            </th>
                            <th style="text-align:right;">
                                <%= t("header_vc_mins") %>
                            </th>
                        </tr>
                    </thead>
                    <tbody id="leaderboard-body">
                        <tr>
                            <td colspan="6" style="text-align:center; padding:20px;" class="muted">
                                <%= t("loading_leaderboard") %>
                            </td>
                        </tr>
                    </tbody>
                </table>
            </div>
        </div>

        <div id="card-raid" class="card" style="padding:15px; margin-bottom:0;">
            <h4
                style="margin:0 0 10px 0; font-size:13px; display:flex; align-items:center; justify-content:space-between; gap:6px;">
                <span>🛡️ <%= t("anti_raid_security") %></span>
            </h4>
            <table class="data-table" style="font-size:12px;">
                <thead>
                    <tr>
                        <th style="text-align:left">
                            <%= t("header_user") %>
                        </th>
                        <th style="text-align:right">
                            <%= t("header_count") %>
                        </th>
                        <th style="text-align:right">
                            <%= t("action") %>
                        </th>
                    </tr>
                </thead>
                <tbody id="topNg"></tbody>
            </table>
        </div>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
    <script>
        document.addEventListener('DOMContentLoaded', () => {
            if (typeof initDashboard === 'function') initDashboard();
        });
    </script>