<style>
    .hero-section {
        flex: 1;
        display: flex;
        flex-direction: column;
        justify-content: center;
        align-items: center;
        text-align: center;
        padding: 0;
        position: relative;
        overflow: hidden;
        background: radial-gradient(circle at 20% 30%, rgba(29, 155, 240, 0.15), transparent 40%),
                    radial-gradient(circle at 80% 70%, rgba(249, 24, 128, 0.15), transparent 40%),
                    #000;
    }

    .hero-content {
        z-index: 10;
        max-width: 1200px;
        width: 100%;
        padding: 0 40px;
        animation: contentAppear 1.5s cubic-bezier(0.16, 1, 0.3, 1);
    }

    @keyframes contentAppear {
        from {
            opacity: 0;
            transform: translateY(30px) scale(0.95);
            filter: blur(10px);
        }
        to {
            opacity: 1;
            transform: translateY(0) scale(1);
            filter: blur(0);
        }
    }

    @keyframes cardAppear {
        from {
            opacity: 0;
            transform: translateY(40px) scale(0.98);
        }

        to {
            opacity: 1;
            transform: translateY(0) scale(1);
        }
    }

    .hero-title {
        font-size: clamp(60px, 12vw, 120px);
        font-weight: 900;
        margin-bottom: 24px;
        letter-spacing: -5px;
        line-height: 0.85;
        background: linear-gradient(to bottom, #fff 40%, rgba(255, 255, 255, 0.4) 100%);
        -webkit-background-clip: text;
        -webkit-text-fill-color: transparent;
        filter: drop-shadow(0 0 30px rgba(255, 255, 255, 0.1));
    }

    .hero-subtitle {
        font-size: clamp(18px, 3vw, 24px);
        color: #fff;
        font-weight: 600;
        margin-bottom: 24px;
        letter-spacing: 2px;
        text-transform: uppercase;
        opacity: 0.9;
    }

    .hero-desc {
        font-size: clamp(18px, 2vw, 22px);
        color: rgba(255, 255, 255, 0.6);
        margin-bottom: 60px;
        max-width: 700px;
        margin-left: auto;
        margin-right: auto;
        line-height: 1.6;
        font-weight: 400;
    }

    .cta-group {
        display: flex;
        justify-content: center;
        gap: 24px;
        flex-wrap: wrap;
    }

    .btn-premium {
        padding: 20px 48px;
        font-size: 18px;
        font-weight: 800;
        border-radius: 100px;
        transition: all 0.4s cubic-bezier(0.16, 1, 0.3, 1);
        text-transform: uppercase;
        letter-spacing: 1px;
    }

    .btn-login {
        background: #fff;
        color: #000;
        border: none;
    }

    .btn-login:hover {
        transform: translateY(-5px) scale(1.05);
        box-shadow: 0 15px 30px rgba(255, 255, 255, 0.2);
    }

    .btn-ghost {
        background: rgba(255, 255, 255, 0.05);
        color: #fff;
        border: 1px solid rgba(255, 255, 255, 0.1);
    }

    .btn-ghost:hover {
        background: rgba(255, 255, 255, 0.1);
        border-color: rgba(255, 255, 255, 0.3);
        transform: translateY(-5px);
    }

    .bg-blur {
        position: absolute;
        width: 800px;
        height: 800px;
        border-radius: 50%;
        filter: blur(150px);
        z-index: 1;
        opacity: 0.2;
        animation: float 25s infinite alternate ease-in-out;
    }

    @keyframes float {
        0% { transform: translate(-10%, -10%) rotate(0deg) scale(1); }
        100% { transform: translate(10%, 10%) rotate(180deg) scale(1.2); }
    }
</style>

<div class="hero-section">
    <div class="bg-blur" style="top: -20%; left: -10%; background: #1DA1F2;"></div>
    <div class="bg-blur" style="bottom: -20%; right: -10%; background: #f91880; animation-delay: -5s;"></div>
    <div class="bg-blur" style="top: 20%; right: 10%; background: #1DA1F2; width: 400px; height: 400px; opacity: 0.1; animation-duration: 15s;"></div>

    <div class="hero-content">
        <div class="hero-subtitle">
            <%= t("subtitle") %>
        </div>
        <h1 class="hero-title">AkatsukiBot</h1>
        <p class="hero-desc">
            <%= t("app_desc") %>
        </p>

        <div class="cta-group">
            <a href="/login" class="btn-premium btn-login">
                <%= t("login") %>
            </a>
            <a href="/features" class="btn-premium btn-ghost">
                <%= t("view_features") %>
            </a>
        </div>
    </div>
</div>