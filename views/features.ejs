<!-- ===== 利用開始の流れ (v2.9.1 - Reordered to bottom) ===== -->
<div style="max-width:1000px; margin: 100px auto 120px; padding: 0 20px;">
    <div style="text-align: center; margin-bottom: 60px;">
        <h2
            style="font-size:36px; margin-bottom:15px; background: linear-gradient(135deg, var(--accent-color) 0%, #fff 100%); -webkit-background-clip: text; background-clip: text; -webkit-text-fill-color: transparent; font-weight: 900;">
            <%= t("how_to_title") %>
        </h2>
        <div style="width: 60px; height: 4px; background: var(--accent-color); margin: 0 auto; border-radius: 2px;">
        </div>
    </div>

    <div style="display:grid; grid-template-columns: repeat(auto-fit, minmax(300px, 1fr)); gap:25px; margin-top:30px;">

        <!-- Step 1 -->
        <div
            style="background:rgba(25,39,52,0.3); border:1px solid rgba(255,255,255,0.05); backdrop-filter: blur(10px); border-radius:24px; padding:35px; position:relative; box-shadow: 0 10px 30px rgba(0,0,0,0.2);">
            <div
                style="position:absolute; top:-18px; left:30px; background:var(--primary-color); color:#fff; font-size:12px; font-weight:900; padding:6px 18px; border-radius:30px; letter-spacing:1px; box-shadow: 0 4px 12px rgba(29,161,242,0.3);">
                STEP 1</div>
            <h4 style="margin:15px 0 12px; font-size:20px; font-weight: 800;">🤖 <%= t("step1_title") %>
            </h4>
            <p style="color:#8899a6; font-size:15px; line-height:1.8; margin:0;">
                <%= t("step1_desc") %>
            </p>
        </div>

        <!-- Step 2 -->
        <div
